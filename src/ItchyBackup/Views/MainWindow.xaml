                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="8"/>
                              <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                              <TextBlock Text="kullanıcı adı" FontSize="9" FontFamily="Consolas"
                                         Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,2"/>
                              <TextBox Style="{StaticResource ItchyTextBox}"
                                       Text="{Binding NetworkUsername, UpdateSourceTrigger=PropertyChanged}"
                                       FontFamily="Consolas" FontSize="11" Height="30"
                                       VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                              <TextBlock Text="domain" FontSize="9" FontFamily="Consolas"
                                         Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,2"/>
                              <TextBox Style="{StaticResource ItchyTextBox}"
                                       Text="{Binding NetworkDomain, UpdateSourceTrigger=PropertyChanged}"
                                       FontFamily="Consolas" FontSize="11" Height="30"
                                       VerticalContentAlignment="Center"/>
                            </StackPanel>
                          </Grid>
                          <TextBlock Text="parola" FontSize="9" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,2"/>
                          <TextBox Style="{StaticResource ItchyTextBox}"
                                   Text="{Binding NetworkPassword, UpdateSourceTrigger=PropertyChanged}"
                                   FontFamily="Consolas" FontSize="11" Height="30"
                                   VerticalContentAlignment="Center"/>
                          <TextBlock Text="Parola profilde saklanmaz." FontSize="9" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextTertiary}" Margin="0,4,0,0"/>
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <!-- Yedek Rotasyonu -->
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Margin="0,0,0,12" Padding="14,12">
                      <StackPanel>
                        <TextBlock Text="YEDEK ROTASYONU" FontSize="9" FontFamily="Consolas"
                                   Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
                        <ComboBox Style="{StaticResource ItchyComboBox}"
                                  SelectedIndex="{Binding RotationPolicyIndex}" Height="32">
                          <ComboBoxItem FontFamily="Segoe UI" FontSize="12">
                            <TextBlock Text="Devre dışı — tüm yedekler tutulur"/>
                          </ComboBoxItem>
                          <ComboBoxItem FontFamily="Segoe UI" FontSize="12">
                            <TextBlock Text="Son N yedeği tut"/>
                          </ComboBoxItem>
                          <ComboBoxItem FontFamily="Segoe UI" FontSize="12">
                            <TextBlock Text="X günden eskileri sil"/>
                          </ComboBoxItem>
                        </ComboBox>
                        <!-- KeepLastN -->
                        <StackPanel Margin="0,8,0,0">
                          <StackPanel.Style>
                            <Style TargetType="StackPanel">
                              <Setter Property="Visibility" Value="Collapsed"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding RotationIsKeepLastN}" Value="True">
                                  <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </StackPanel.Style>
                          <TextBlock Text="kaç yedek tutulsun" FontSize="9" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4"/>
                          <TextBox Style="{StaticResource ItchyTextBox}"
                                   Text="{Binding RotationKeepLastN, UpdateSourceTrigger=PropertyChanged}"
                                   FontFamily="Consolas" FontSize="12" Height="32" Width="80"
                                   HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <!-- DeleteOlderThanDays -->
                        <StackPanel Margin="0,8,0,0">
                          <StackPanel.Style>
                            <Style TargetType="StackPanel">
                              <Setter Property="Visibility" Value="Collapsed"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding RotationIsDeleteOlderThan}" Value="True">
                                  <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </StackPanel.Style>
                          <TextBlock Text="kaç günden eski yedekler silinsin" FontSize="9" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4"/>
                          <TextBox Style="{StaticResource ItchyTextBox}"
                                   Text="{Binding RotationDeleteOlderThanDays, UpdateSourceTrigger=PropertyChanged}"
                                   FontFamily="Consolas" FontSize="12" Height="32" Width="80"
                                   HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <!-- Sıkıştırma grubu -->
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Margin="0,0,0,12" Padding="14,12">
                      <StackPanel>
                        <TextBlock Text="SIKIŞTURMA" FontSize="9" FontFamily="Consolas"
                                   Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
                        <CheckBox Style="{StaticResource ItchyCheckBox}" IsChecked="{Binding UseZip}"
                                  Margin="0,0,0,0">
                          <TextBlock Text="ZIP olarak sıkıştır" FontFamily="Segoe UI" FontSize="12"
                                     Foreground="{DynamicResource TextPrimary}"/>
                        </CheckBox>
                        <StackPanel Margin="0,8,0,0">
                          <StackPanel.Style>
                            <Style TargetType="StackPanel">
                              <Setter Property="Visibility" Value="Collapsed"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding UseZip}" Value="True">
                                  <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </StackPanel.Style>
                          <Separator Margin="0,0,0,8"/>
                          <CheckBox Style="{StaticResource ItchyCheckBox}" IsChecked="{Binding UsePassword}"
                                    Margin="0,0,0,6">
                            <TextBlock Text="AES-256 şifreleme" FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{DynamicResource TextPrimary}"/>
                          </CheckBox>
                          <StackPanel>
                            <StackPanel.Style>
                              <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding UsePassword}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </StackPanel.Style>
                            <TextBox Style="{StaticResource ItchyTextBox}" Margin="0,4,0,0"
                                     Text="{Binding ZipPassword, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" Height="32" VerticalContentAlignment="Center"/>
                          </StackPanel>
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <!-- Güvenlik grubu -->
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Margin="0,0,0,12" Padding="14,12">
                      <StackPanel>
                        <TextBlock Text="GÜVENLİK" FontSize="9" FontFamily="Consolas"
                                   Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
                        <CheckBox Style="{StaticResource ItchyCheckBox}" IsChecked="{Binding VerifyChecksum}"
                                  Margin="0,0,0,8">
                          <TextBlock Text="SHA-256 checksum" FontFamily="Segoe UI" FontSize="12"
                                     Foreground="{DynamicResource TextPrimary}"/>
                        </CheckBox>
                        <CheckBox Style="{StaticResource ItchyCheckBox}" IsChecked="{Binding UseVss}">
                          <TextBlock Text="VSS (açık dosya desteği)" FontFamily="Segoe UI" FontSize="12"
                                     Foreground="{DynamicResource TextPrimary}"/>
                        </CheckBox>
                      </StackPanel>
                    </Border>

                    <!-- Artımlı Yedekleme -->
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Margin="0,0,0,12" Padding="14,12">
                      <StackPanel>
                        <TextBlock Text="YEDEKLEME TÜRÜ" FontSize="9" FontFamily="Consolas"
                                   Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
                        <CheckBox Style="{StaticResource ItchyCheckBox}" IsChecked="{Binding IsIncremental}">
                          <TextBlock Text="Artımlı yedekleme" FontFamily="Segoe UI" FontSize="12"
                                     Foreground="{DynamicResource TextPrimary}"/>
                        </CheckBox>
                        <StackPanel Margin="0,6,0,0">
                          <StackPanel.Style>
                            <Style TargetType="StackPanel">
                              <Setter Property="Visibility" Value="Collapsed"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsIncremental}" Value="True">
                                  <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </StackPanel.Style>
                          <TextBlock Text="Yalnızca değişen dosyaları yedekler." FontSize="10"
                                     FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                                     Margin="0,0,0,8"/>
