                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </Grid>

          <!-- ═══ ZAMANLAYICI ═══════════════════════════════════════════ -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPanelScheduler}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
              <RowDefinition Height="48"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{DynamicResource BgPrimary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
              <TextBlock Text="Otomatik Zamanlayıcı" FontSize="15" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                         Margin="16,0" FontFamily="Segoe UI"/>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="24,16,24,16" MaxWidth="680">

                <!-- Aktif toggle -->
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16">
                  <Grid Margin="16,14">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Zamanlayıcıyı Etkinleştir" FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                      <TextBlock Text="{Binding SchedulerStatus}" FontSize="10"
                                 Foreground="{DynamicResource AccentLight}" FontFamily="Consolas"
                                 Margin="0,3,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{StaticResource ItchyCheckBox}"
                              IsChecked="{Binding SchedulerEnabled}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>

                <!-- Günler -->
                <TextBlock Text="YEDEKLEME GÜNLERİ" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16" Padding="16,14">
                  <WrapPanel>
                    <!-- Gün butonları macro -->
                    <Border Margin="0,0,8,8" CornerRadius="8" Cursor="Hand" Width="80" Height="52" BorderThickness="1">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="{DynamicResource BgQuaternary}"/>
                          <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding SchedMon}" Value="True">
                              <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                              <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleMonCommand}"/>
                      </Border.InputBindings>
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Pzt" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" FontFamily="Segoe UI">
                          <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/><Style.Triggers><DataTrigger Binding="{Binding SchedMon}" Value="True"><Setter Property="Foreground" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="MON" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiary}"/>
                      </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,8" CornerRadius="8" Cursor="Hand" Width="80" Height="52" BorderThickness="1">
                      <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource BgQuaternary}"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding SchedulerTue}" Value="True"><Setter Property="Background" Value="{DynamicResource AccentSubtle}"/><Setter Property="BorderBrush" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                      <Border.InputBindings><MouseBinding MouseAction="LeftClick" Command="{Binding ToggleTueCommand}"/></Border.InputBindings>
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Sal" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" FontFamily="Segoe UI"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/><Style.Triggers><DataTrigger Binding="{Binding SchedulerTue}" Value="True"><Setter Property="Foreground" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        <TextBlock Text="TUE" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiary}"/>
                      </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,8" CornerRadius="8" Cursor="Hand" Width="80" Height="52" BorderThickness="1">
                      <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource BgQuaternary}"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding SchedWed}" Value="True"><Setter Property="Background" Value="{DynamicResource AccentSubtle}"/><Setter Property="BorderBrush" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                      <Border.InputBindings><MouseBinding MouseAction="LeftClick" Command="{Binding ToggleWedCommand}"/></Border.InputBindings>
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Çar" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" FontFamily="Segoe UI"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/><Style.Triggers><DataTrigger Binding="{Binding SchedWed}" Value="True"><Setter Property="Foreground" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        <TextBlock Text="WED" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiary}"/>
                      </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,8" CornerRadius="8" Cursor="Hand" Width="80" Height="52" BorderThickness="1">
                      <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource BgQuaternary}"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding SchedThu}" Value="True"><Setter Property="Background" Value="{DynamicResource AccentSubtle}"/><Setter Property="BorderBrush" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                      <Border.InputBindings><MouseBinding MouseAction="LeftClick" Command="{Binding ToggleThuCommand}"/></Border.InputBindings>
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Per" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" FontFamily="Segoe UI"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/><Style.Triggers><DataTrigger Binding="{Binding SchedThu}" Value="True"><Setter Property="Foreground" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        <TextBlock Text="THU" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiary}"/>
                      </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,8" CornerRadius="8" Cursor="Hand" Width="80" Height="52" BorderThickness="1">
                      <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource BgQuaternary}"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding SchedFri}" Value="True"><Setter Property="Background" Value="{DynamicResource AccentSubtle}"/><Setter Property="BorderBrush" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                      <Border.InputBindings><MouseBinding MouseAction="LeftClick" Command="{Binding ToggleFriCommand}"/></Border.InputBindings>
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Cum" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" FontFamily="Segoe UI"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/><Style.Triggers><DataTrigger Binding="{Binding SchedFri}" Value="True"><Setter Property="Foreground" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        <TextBlock Text="FRI" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiary}"/>
                      </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,8" CornerRadius="8" Cursor="Hand" Width="80" Height="52" BorderThickness="1">
                      <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource BgQuaternary}"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding SchedSat}" Value="True"><Setter Property="Background" Value="{DynamicResource AccentSubtle}"/><Setter Property="BorderBrush" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                      <Border.InputBindings><MouseBinding MouseAction="LeftClick" Command="{Binding ToggleSatCommand}"/></Border.InputBindings>
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Cmt" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" FontFamily="Segoe UI"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/><Style.Triggers><DataTrigger Binding="{Binding SchedSat}" Value="True"><Setter Property="Foreground" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        <TextBlock Text="SAT" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiary}"/>
                      </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,8" CornerRadius="8" Cursor="Hand" Width="80" Height="52" BorderThickness="1">
                      <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource BgQuaternary}"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding SchedSun}" Value="True"><Setter Property="Background" Value="{DynamicResource AccentSubtle}"/><Setter Property="BorderBrush" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                      <Border.InputBindings><MouseBinding MouseAction="LeftClick" Command="{Binding ToggleSunCommand}"/></Border.InputBindings>
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Paz" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" FontFamily="Segoe UI"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/><Style.Triggers><DataTrigger Binding="{Binding SchedSun}" Value="True"><Setter Property="Foreground" Value="{DynamicResource Accent}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        <TextBlock Text="SUN" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiary}"/>
                      </StackPanel>
                    </Border>
                  </WrapPanel>
                </Border>

                <!-- Saat ve profil -->
                <TextBlock Text="SAAT VE PROFİL" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16" Padding="16,14">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="14"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sol: Saat ve Dakika seçici -->
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Yedekleme Saati" FontSize="11" FontWeight="Medium"
                                 Foreground="{DynamicResource TextSecondary}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="72"/>
                          <ColumnDefinition Width="22"/>
                          <ColumnDefinition Width="72"/>
                        </Grid.ColumnDefinitions>

                        <!-- Saat spinner -->
                        <StackPanel Grid.Column="0">
                          <TextBlock Text="SAAT" FontSize="8" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextTertiary}"
                                     HorizontalAlignment="Center" Margin="0,0,0,3"/>
                          <Button Style="{StaticResource SpinArrowButton}" Height="20"
                                  Command="{Binding IncrementHourCommand}"
                                  HorizontalAlignment="Stretch">
                            <Path Data="M0,5 L5,0 L10,5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Button>
                          <Border Background="{DynamicResource BgQuaternary}"
                                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                  CornerRadius="7" Height="40" Margin="0,2"
                                  PreviewMouseWheel="HourSpinner_MouseWheel">
                            <TextBlock Text="{Binding SchedulerHour, StringFormat={}{0:D2}}"
                                       FontSize="19" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{DynamicResource Accent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <Button Style="{StaticResource SpinArrowButton}" Height="20"
                                  Command="{Binding DecrementHourCommand}"
                                  HorizontalAlignment="Stretch">
                            <Path Data="M0,0 L5,5 L10,0" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Button>
                        </StackPanel>

                        <!-- Ayırıcı -->
                        <TextBlock Grid.Column="1" Text=":" FontSize="22" FontWeight="Bold"
                                   FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8,0,0"/>

                        <!-- Dakika spinner -->
                        <StackPanel Grid.Column="2">
                          <TextBlock Text="DAKİKA" FontSize="8" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextTertiary}"
                                     HorizontalAlignment="Center" Margin="0,0,0,3"/>
                          <Button Style="{StaticResource SpinArrowButton}" Height="20"
                                  Command="{Binding IncrementMinuteCommand}"
                                  HorizontalAlignment="Stretch">
                            <Path Data="M0,5 L5,0 L10,5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Button>
                          <Border Background="{DynamicResource BgQuaternary}"
                                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                  CornerRadius="7" Height="40" Margin="0,2"
                                  PreviewMouseWheel="MinuteSpinner_MouseWheel">
                            <TextBlock Text="{Binding SchedulerMinute, StringFormat={}{0:D2}}"
                                       FontSize="19" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{DynamicResource Accent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <Button Style="{StaticResource SpinArrowButton}" Height="20"
                                  Command="{Binding DecrementMinuteCommand}"
                                  HorizontalAlignment="Stretch">
                            <Path Data="M0,0 L5,5 L10,0" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Button>
                        </StackPanel>
                      </Grid>
                    </StackPanel>

                    <!-- Sağ: Profil seçici -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                      <TextBlock Text="Kullanılacak Profil" FontSize="11" FontWeight="Medium"
                                 Foreground="{DynamicResource TextSecondary}" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                      <ComboBox Style="{StaticResource ItchyComboBox}"
                                ItemsSource="{Binding SavedProfiles}"
                                SelectedValuePath="ProfileName"
                                SelectedValue="{Binding SchedulerProfile}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding ProfileName}" FontFamily="Segoe UI" FontSize="12"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </StackPanel>
                  </Grid>
                </Border>

                <!-- Yedek klasörü kısayolu -->
                <TextBlock Text="VARSAYILAN YEDEK KLASÖRÜ" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="16,12" Margin="0,0,0,16">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                      <TextBlock Text="Yedek Hedef Klasörü" FontSize="11" FontWeight="Medium"
                                 Foreground="{DynamicResource TextSecondary}" FontFamily="Segoe UI"
                                 Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding DestinationPath}" FontSize="10" FontFamily="Consolas"
                                 Foreground="{DynamicResource TextTertiary}" TextTrimming="CharacterEllipsis"
                                 MaxWidth="800"/>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseDestinationCommand}"
                            Margin="12,0,0,0" Padding="12,6">
                      <TextBlock Text="Klasör Seç" FontSize="11" FontFamily="Segoe UI"/>
                    </Button>
                  </Grid>
                </Border>

                <!-- Windows başlatma uyarısı -->
                <Border CornerRadius="8" Padding="14,12" Margin="0,0,0,0"
                        Background="{DynamicResource AccentSubtle}" BorderBrush="{DynamicResource Accent}" BorderThickness="1">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="ⓘ" FontSize="15"
                               Foreground="{DynamicResource AccentLight}"
                               VerticalAlignment="Top" Margin="0,0,10,0"/>
                    <TextBlock FontSize="11" FontFamily="Segoe UI" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}" LineHeight="1">
                      <Run Text="Zamanlayıcının PC açıldığında otomatik çalışması için "/>
                      <Run Text="Ayarlar" FontWeight="SemiBold" Foreground="{DynamicResource AccentLight}"/>
                      <Run Text=" ekranından "/>
                      <Run Text="'Windows ile Başlat'" FontWeight="SemiBold" Foreground="{DynamicResource AccentLight}"/>
                      <Run Text=" seçeneğini etkinleştirin."/>
                    </TextBlock>
                  </DockPanel>
                </Border>

                <Button Style="{StaticResource PrimaryButton}" Command="{Binding SaveSchedulerCommand}"
                        HorizontalAlignment="Stretch" Height="44" Margin="0,16,0,0">
                  <TextBlock Text="Zamanlayıcıyı Kaydet" FontSize="13" FontWeight="Bold"
                             FontFamily="Segoe UI" Foreground="White"/>
                </Button>

              </StackPanel>
            </ScrollViewer>
          </Grid>


          <!-- ═══ GERİ YÜKLE ═════════════════════════════════════════════ -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPanelRestore}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
              <RowDefinition Height="48"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{DynamicResource BgPrimary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
              <TextBlock Text="Yedekten Geri Yükle" FontSize="15" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                         Margin="16,0" FontFamily="Segoe UI"/>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="20,16,20,16">

                <!-- 1. Yedek seçimi -->
                <TextBlock Text="1. YEDEK SEÇİMİ" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,8"/>
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16">
                  <ListBox ItemsSource="{Binding AvailableBackups}"
                           SelectedItem="{Binding SelectedBackupForRestore}"
                           MaxHeight="200"
                           Background="Transparent" BorderThickness="0"
                           ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                      <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                          <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </ControlTemplate>
                          </Setter.Value>
                        </Setter>
                      </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Padding="14,10" Cursor="Hand"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="Background" Value="Transparent"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                  <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                  <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                                </Trigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="20"/>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="Auto"/>
                              <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton Grid.Column="0" GroupName="RestoreBackup" VerticalAlignment="Center"
                                         IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Mode=OneWay}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                              <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"
                                         Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                              <TextBlock Text="{Binding Date}" FontSize="10" FontFamily="Consolas"
                                         Foreground="{DynamicResource TextTertiary}"/>
                            </StackPanel>
                            <Border Grid.Column="2" CornerRadius="8" Padding="6,2" VerticalAlignment="Center"
                                    Margin="0,0,8,0" Background="{DynamicResource BgQuaternary}">
                              <TextBlock Text="ZIP" FontSize="9" FontFamily="Consolas"
                                         Foreground="{DynamicResource AccentLight}"
                                         Visibility="{Binding IsZip, Converter={StaticResource BoolToVis}}"/>
                            </Border>
                            <TextBlock Grid.Column="3" Text="{Binding SizeText}" FontSize="11"
                                       FontFamily="Consolas" Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center"/>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <!-- 2. Hedef konum -->
                <TextBlock Text="2. HEDEF KONUM" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0" Style="{StaticResource ItchyTextBox}"
                           Text="{Binding RestoreTargetPath, UpdateSourceTrigger=PropertyChanged}"
                           Height="36" FontFamily="Consolas" FontSize="11"
                           VerticalContentAlignment="Center"/>
                  <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                          Command="{Binding BrowseRestoreTargetCommand}"
                          Margin="6,0,0,0" Padding="10,6" Height="36">
                    <TextBlock Text="📁" FontFamily="Segoe UI Emoji" FontSize="13"/>
                  </Button>
                </Grid>

                <!-- 3. Seçenekler -->
                <TextBlock Text="3. SEÇENEKLER" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,8"/>
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16" Padding="14,12">
                  <StackPanel>
                    <CheckBox Style="{StaticResource ItchyCheckBox}" IsChecked="{Binding RestoreOverwrite}"
                              Margin="0,0,0,8">
                      <TextBlock Text="Mevcut dosyaların üzerine yaz" FontFamily="Segoe UI" FontSize="12"
                                 Foreground="{DynamicResource TextPrimary}"/>
                    </CheckBox>
                    <CheckBox Style="{StaticResource ItchyCheckBox}" IsChecked="{Binding RestorePartial}">
                      <TextBlock Text="Kısmi geri yükleme (sadece seçilen dosyalar)"
                                 FontFamily="Segoe UI" FontSize="12"
                                 Foreground="{DynamicResource TextPrimary}"/>
                    </CheckBox>
                    <StackPanel>
                      <StackPanel.Style>
                        <Style TargetType="StackPanel">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedBackupForRestore.IsZip}" Value="True">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </StackPanel.Style>
                      <Separator Margin="0,8"/>
                      <TextBlock Text="ZIP Şifresi (gerekiyorsa)" FontSize="11"
                                 Foreground="{DynamicResource TextSecondary}" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                      <TextBox Style="{StaticResource ItchyTextBox}" Height="32"
                               Text="{Binding RestoreZipPassword, UpdateSourceTrigger=PropertyChanged}"
                               FontFamily="Consolas" VerticalContentAlignment="Center"/>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <!-- 4. Kısmi geri yükleme - klasör listesi -->
                <StackPanel>
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Collapsed"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding RestorePartial}" Value="True">
                          <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <DockPanel Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left" Text="4. KLASÖR SEÇİMİ"
                               FontSize="9" FontFamily="Consolas"
                               Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                      <Button Style="{StaticResource SecondaryButton}"
                              Command="{Binding SelectAllRestoreItemsCommand}"
                              Padding="10,4" FontSize="10" Margin="0,0,4,0">
                        <TextBlock Text="Tümü"/>
                      </Button>
                      <Button Style="{StaticResource SecondaryButton}"
                              Command="{Binding ClearAllRestoreItemsCommand}"
                              Padding="10,4" FontSize="10">
                        <TextBlock Text="Hiçbiri"/>
                      </Button>
                    </StackPanel>
                  </DockPanel>
                  <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          MaxHeight="320">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding RestoreFolders}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <StackPanel>
                              <!-- Ana klasör satırı -->
                              <Border Padding="10,8"
                                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                  </Grid.ColumnDefinitions>
                                  <!-- Genişlet / Daralt oku -->
                                  <Button Grid.Column="0" Command="{Binding ToggleExpandCommand}"
                                          Background="Transparent" BorderThickness="0" Padding="0"
                                          Cursor="Hand" VerticalAlignment="Center" Width="16" Height="16">
                                    <Button.Style>
                                      <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </Button.Style>
                                    <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                                          StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{DynamicResource TextTertiary}">
                                      <Path.Style>
                                        <Style TargetType="Path">
                                          <Setter Property="Data" Value="M2,1 L7,5 L2,9"/>
                                          <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                              <Setter Property="Data" Value="M1,2 L5,7 L9,2"/>
                                            </DataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </Path.Style>
                                    </Path>
                                  </Button>
                                  <CheckBox Grid.Column="1" Style="{StaticResource ItchyCheckBox}"
                                            IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                  <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                                    <TextBlock Text="{Binding SubText}" FontSize="9" FontFamily="Consolas"
                                               Foreground="{DynamicResource TextTertiary}"/>
                                  </StackPanel>
                                  <TextBlock Grid.Column="3" Text="{Binding SizeText}" FontSize="10"
                                             FontFamily="Consolas" Foreground="{DynamicResource TextSecondary}"
                                             VerticalAlignment="Center"/>
                                </Grid>
                              </Border>
                              <!-- Alt klasörler -->
                              <ItemsControl ItemsSource="{Binding Children}">
                                <ItemsControl.Style>
                                  <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Border Padding="10,7" Margin="22,0,0,0"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                      <Grid>
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="22"/>
                                          <ColumnDefinition Width="*"/>
                                          <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" Style="{StaticResource ItchyCheckBox}"
                                                  IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                          <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                     Foreground="{DynamicResource TextSecondary}" FontFamily="Segoe UI"/>
                                          <TextBlock Text="{Binding SubText}" FontSize="9" FontFamily="Consolas"
                                                     Foreground="{DynamicResource TextTertiary}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontSize="10"
                                                   FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                                                   VerticalAlignment="Center"/>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Border>
                </StackPanel>

              </StackPanel>
            </ScrollViewer>

            <!-- Alt: Geri yükle butonu + progress -->
            <Border Grid.Row="2" Background="{DynamicResource BgSecondary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="20,4.3">
              <StackPanel>
                <Border Visibility="{Binding IsRestoring, Converter={StaticResource BoolToVis}}" Margin="0,0,0,10">
                  <StackPanel>
                    <DockPanel Margin="0,0,0,4">
                      <TextBlock DockPanel.Dock="Right" FontFamily="Consolas" FontSize="10"
                                 Foreground="{DynamicResource AccentLight}" FontWeight="Bold">
                        <Run Text="{Binding RestoreProgressPercent, StringFormat='{}{0:F0}', Mode=OneWay}"/>
                        <Run Text="%"/>
                      </TextBlock>
                      <TextBlock Text="{Binding RestoreCurrentFile}" FontSize="10"
                                 FontFamily="Consolas" Foreground="{DynamicResource TextSecondary}"
                                 TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                    <ProgressBar Style="{StaticResource ItchyProgressBar}"
                                 Value="{Binding RestoreProgressPercent}" Maximum="100"/>
                    <TextBlock Text="{Binding RestoreProgressText}" FontSize="10" FontFamily="Consolas"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Button Grid.Column="0" Style="{StaticResource PrimaryButton}"
                          Command="{Binding StartRestoreCommand}" Height="44">
                    <Button.IsEnabled>
                      <Binding Path="IsRestoring" Converter="{StaticResource InverseBool}"/>
                    </Button.IsEnabled>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="↻  " FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                      <TextBlock Text="Geri Yüklemeyi Başlat" FontSize="13" FontWeight="Bold"
                                 FontFamily="Segoe UI" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button Grid.Column="1" Style="{StaticResource DangerButton}"
                          Command="{Binding CancelRestoreCommand}"
                          Visibility="{Binding IsRestoring, Converter={StaticResource BoolToVis}}"
                          Margin="8,0,0,0" Padding="16,8">
                    <TextBlock Text="✕" FontSize="14"/>
                  </Button>
                </Grid>
              </StackPanel>
            </Border>
          </Grid>

          <!-- ═══ SONUÇ RAPORU ══════════════════════════════════════════ -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPanelResult}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
              <RowDefinition Height="48"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{DynamicResource BgPrimary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
              <TextBlock Text="Yedekleme Raporu" FontSize="15" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                         Margin="16,0" FontFamily="Segoe UI"/>
            </Border>

            <ScrollViewer Grid.Row="1" Margin="20,16" VerticalScrollBarVisibility="Auto">
              <StackPanel MaxWidth="700">
                <!-- Genel durum -->
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16" Padding="20,16">
                  <StackPanel>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="✓ Yedekleme Tamamlandı" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource Success}" FontFamily="Segoe UI">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding LastBackupResult.Success}" Value="False">
                                  <Setter Property="Text" Value="⚠ Yedekleme Hatalarla Tamamlandı"/>
                                  <Setter Property="Foreground" Value="{DynamicResource Warning}"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding LastBackupResult.BackupPath}" FontSize="10"
                                   FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                                   Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- İstatistikler -->
                <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">
                  <Border Background="{DynamicResource BgCard}" CornerRadius="10" Margin="0,0,8,0"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                      <TextBlock Text="KATEGORİ" FontSize="9" FontFamily="Consolas"
                                 Foreground="{DynamicResource TextTertiary}"/>
                      <TextBlock Text="{Binding LastBackupResult.TotalCategories}" FontSize="22" FontWeight="Bold"
                                 Foreground="{DynamicResource AccentLight}" FontFamily="Consolas" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                  <Border Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4,0"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                      <TextBlock Text="DOSYA" FontSize="9" FontFamily="Consolas"
                                 Foreground="{DynamicResource TextTertiary}"/>
                      <TextBlock Text="{Binding LastBackupResult.FilesCopied}" FontSize="22" FontWeight="Bold"
                                 Foreground="{DynamicResource Success}" FontFamily="Consolas" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                  <Border Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4,0"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                      <TextBlock Text="HATA" FontSize="9" FontFamily="Consolas"
                                 Foreground="{DynamicResource TextTertiary}"/>
                      <TextBlock Text="{Binding LastBackupResult.Errors.Count}" FontSize="22" FontWeight="Bold"
                                 Foreground="{DynamicResource Danger}" FontFamily="Consolas" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                  <Border Background="{DynamicResource BgCard}" CornerRadius="10" Margin="8,0,0,0"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                      <TextBlock Text="SÜRE" FontSize="9" FontFamily="Consolas"
                                 Foreground="{DynamicResource TextTertiary}"/>
                      <TextBlock Text="{Binding LastBackupResult.Elapsed, StringFormat=mm\:ss}" FontSize="22" FontWeight="Bold"
                                 Foreground="{DynamicResource Info}" FontFamily="Consolas" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                </UniformGrid>

                <!-- Artımlı bilgi (yalnızca artımlı yedekte görünür) -->
                <Border Background="{DynamicResource BgCard}" CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,-8,0,12" Padding="12,8">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding LastBackupResult.IsIncremental}" Value="True">
                          <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <DockPanel>
                    <TextBlock Text="ARTIMLI" FontSize="9" FontFamily="Consolas"
                               Foreground="{DynamicResource AccentLight}" VerticalAlignment="Center"
                               DockPanel.Dock="Left" Margin="0,0,10,0"/>
                    <TextBlock FontSize="11" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center">
                      <Run Text="{Binding LastBackupResult.FilesUnchanged, Mode=OneWay}"/>
                      <Run Text=" dosya değişmedi (atlandı)"/>
                    </TextBlock>
                  </DockPanel>
                </Border>

                <!-- Doğrulama Raporu -->
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16" Padding="16,12"
                        Visibility="{Binding LastBackupResult.VerificationReport, Converter={StaticResource NotNullToVis}}">
                  <StackPanel>
                    <TextBlock Text="DOĞRULAMA" FontSize="9" FontFamily="Consolas"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding LastBackupResult.VerificationReport.Summary}" FontSize="13"
                               Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="Geçerli" FontSize="10" Foreground="{DynamicResource TextTertiary}"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="{Binding LastBackupResult.VerificationReport.Valid}"
                                   FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Success}"
                                   FontFamily="Consolas"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="Eksik" FontSize="10" Foreground="{DynamicResource TextTertiary}"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="{Binding LastBackupResult.VerificationReport.Missing}"
                                   FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Danger}"
                                   FontFamily="Consolas"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Text="Bozuk" FontSize="10" Foreground="{DynamicResource TextTertiary}"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="{Binding LastBackupResult.VerificationReport.Modified}"
                                   FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Warning}"
                                   FontFamily="Consolas"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- Hata listesi -->
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16" Padding="0">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding LastBackupResult.Errors.Count, Converter={StaticResource HasItemsConverter}}" Value="True">
                          <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <StackPanel>
                    <TextBlock Text="HATALAR" FontSize="9" FontFamily="Consolas"
                               Foreground="{DynamicResource Danger}" Margin="16,12,16,8"/>
                    <ItemsControl ItemsSource="{Binding LastBackupResult.Errors}" MaxHeight="160">
                      <ItemsControl.Template>
                        <ControlTemplate>
                          <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter/>
                          </ScrollViewer>
                        </ControlTemplate>
                      </ItemsControl.Template>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Padding="16,4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding}" FontSize="10" FontFamily="Consolas"
                                       Foreground="{DynamicResource Danger}" TextWrapping="Wrap"/>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

              </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource BgSecondary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="20,12">
              <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Command="{Binding CloseResultCommand}" Padding="24,10" Height="40">
                  <TextBlock Text="Kapat" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                             Foreground="White"/>
                </Button>
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenLogFolderCommand}" Padding="16,10" Height="40">
                  <TextBlock Text="📁  Log Klasörü" FontFamily="Segoe UI" FontSize="11"/>
                </Button>
              </DockPanel>
            </Border>
          </Grid>

          <!-- ═══ AYARLAR ═══════════════════════════════════════════════ -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPanelSettings}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
              <RowDefinition Height="48"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{DynamicResource BgPrimary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
              <TextBlock Text="Ayarlar" FontSize="15" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                         Margin="16,0" FontFamily="Segoe UI"/>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="24,16,24,16" MaxWidth="580">

                <!-- HAKKINDA - EN ÜSTTE -->
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20" Padding="16,16">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Itchy Backup" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI">
                        <TextBlock.Foreground>
                          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#6C5CE7" Offset="0"/>
                            <GradientStop Color="#A29BFE" Offset="1"/>
                          </LinearGradientBrush>
                        </TextBlock.Foreground>
                      </TextBlock>
                      <TextBlock Text="v0.7 — Teknik Servis Dosya Yedekleme Aracı" FontSize="11"
                                 Foreground="{DynamicResource TextTertiary}" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                      <TextBlock Text="Created by M.Mert" FontSize="12"
                                 Foreground="{DynamicResource AccentLight}" FontFamily="Segoe UI"
                                 FontWeight="SemiBold" Margin="0,6,0,0"/>
                    </StackPanel>
                    <!-- GitHub Butonu -->
                    <Border Grid.Column="1" VerticalAlignment="Center">
                      <Button Click="GitHubBtn_Click" Cursor="Hand" Background="Transparent"
                              BorderThickness="0" Padding="0">
                        <Border Background="{DynamicResource BgQuaternary}" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderHoverBrush}" BorderThickness="1"
                                Padding="14,10">
                          <StackPanel Orientation="Horizontal">
                            <!-- GitHub Logo SVG -->
                            <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                              <Canvas Width="24" Height="24">
                                <Path Fill="{DynamicResource TextPrimary}"
                                      Data="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.5C9.34,21.58 9.5,21.27 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.5C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z"/>
                              </Canvas>
                            </Viewbox>
                            <TextBlock Text="GitHub" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Border>
                      </Button>
                    </Border>
                  </Grid>
                </Border>

                <!-- GÖRÜNÜM -->
                <TextBlock Text="GÖRÜNÜM" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20" Padding="16,14">
                  <StackPanel>
                    <!-- Dark / Light toggle -->
                    <TextBlock Text="Tema" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"
                               Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                      <Button Command="{Binding SetThemeCommand}" CommandParameter="Dark"
                              Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand">
                        <Border CornerRadius="8" Padding="16,8" BorderThickness="2">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                              <Setter Property="BorderBrush" Value="Transparent"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding ThemeName}" Value="Dark">
                                  <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                          <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🌙" FontFamily="Segoe UI Emoji" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Koyu" FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Border>
                      </Button>
                      <Button Command="{Binding SetThemeCommand}" CommandParameter="Light"
                              Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand"
                              Margin="8,0,0,0">
                        <Border CornerRadius="8" Padding="16,8" BorderThickness="2">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                              <Setter Property="BorderBrush" Value="Transparent"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding ThemeName}" Value="Light">
                                  <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                          <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☀️" FontFamily="Segoe UI Emoji" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Aydınlık" FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Border>
                      </Button>
                    </StackPanel>
                    <Separator Margin="0,0,0,14"/>
                    <!-- Accent color palette -->
                    <TextBlock Text="Vurgu Rengi" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"
                               Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                      <!-- Purple -->
                      <Button Command="{Binding SetAccentCommand}" CommandParameter="#6C5CE7"
                              Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand" Margin="0,0,6,0">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#6C5CE7" BorderThickness="3">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="BorderBrush" Value="Transparent"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding AccentColor}" Value="#6C5CE7">
                                  <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                        </Border>
                      </Button>
                      <!-- Cyan -->
                      <Button Command="{Binding SetAccentCommand}" CommandParameter="#00CEC9"
                              Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand" Margin="0,0,6,0">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#00CEC9" BorderThickness="3">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="BorderBrush" Value="Transparent"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding AccentColor}" Value="#00CEC9">
                                  <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                        </Border>
                      </Button>
                      <!-- Green -->
                      <Button Command="{Binding SetAccentCommand}" CommandParameter="#00B894"
                              Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand" Margin="0,0,6,0">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#00B894" BorderThickness="3">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="BorderBrush" Value="Transparent"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding AccentColor}" Value="#00B894">
                                  <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                        </Border>
                      </Button>
                      <!-- Gold -->
                      <Button Command="{Binding SetAccentCommand}" CommandParameter="#FDCB6E"
                              Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand" Margin="0,0,6,0">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#FDCB6E" BorderThickness="3">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="BorderBrush" Value="Transparent"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding AccentColor}" Value="#FDCB6E">
                                  <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                        </Border>
                      </Button>
                      <!-- Orange -->
                      <Button Command="{Binding SetAccentCommand}" CommandParameter="#E17055"
                              Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand" Margin="0,0,6,0">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#E17055" BorderThickness="3">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="BorderBrush" Value="Transparent"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding AccentColor}" Value="#E17055">
                                  <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                        </Border>
                      </Button>
                      <!-- Pink -->
                      <Button Command="{Binding SetAccentCommand}" CommandParameter="#E84393"
                              Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#E84393" BorderThickness="3">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="BorderBrush" Value="Transparent"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding AccentColor}" Value="#E84393">
                                  <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                        </Border>
                      </Button>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <TextBlock Text="GENEL" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16">
                  <StackPanel>
                    <DockPanel Margin="16,13">
                      <CheckBox DockPanel.Dock="Right" Style="{StaticResource ItchyCheckBox}"
                                IsChecked="{Binding StartWithWindows}" VerticalAlignment="Center"/>
                      <StackPanel>
                        <TextBlock Text="Windows ile başlat" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                        <TextBlock Text="Sistem açılışında otomatik başlat" FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}" FontFamily="Segoe UI"/>
                      </StackPanel>
                    </DockPanel>
                    <Separator/>
                    <DockPanel Margin="16,13">
                      <CheckBox DockPanel.Dock="Right" Style="{StaticResource ItchyCheckBox}"
                                IsChecked="{Binding MinimizeToTray}" VerticalAlignment="Center"/>
                      <StackPanel>
                        <TextBlock Text="Sistem tepsisine küçült" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                        <TextBlock Text="Kapatınca tepside gizle" FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}" FontFamily="Segoe UI"/>
                      </StackPanel>
                    </DockPanel>
                  </StackPanel>
                </Border>

                <TextBlock Text="YEDEKLEME" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <StackPanel Margin="16,13">
                                            <TextBlock Text="Varsayılan Yedek Klasörü" FontSize="13" FontWeight="Medium"
                                 Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Style="{StaticResource ItchyTextBox}"
                                 Text="{Binding DefaultDestination, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" FontSize="11" Height="34" VerticalContentAlignment="Center"/>
                                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseDefaultDestinationCommand}"
                                Margin="6,0,0,0" Padding="10,6" Height="34">
                                                    <TextBlock Text="📁" FontFamily="Segoe UI Emoji" FontSize="13"/>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                        <Separator/>
                                        <DockPanel Margin="16,13">
                                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ItchyCheckBox}"
                                IsChecked="{Binding AutoChecksum}" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="Otomatik checksum doğrulama" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="Her yedek sonrası SHA-256 ile doğrula" FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <Separator/>
                                        <DockPanel Margin="16,13">
                                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ItchyCheckBox}"
                                IsChecked="{Binding SoundNotification}" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="Ses bildirimi" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="Yedekleme tamamlanınca ses çal" FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <Separator/>
                                        <DockPanel Margin="16,13">
                                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ItchyCheckBox}"
                                IsChecked="{Binding OpenFolderAfterBackup}" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="Yedek bitince klasörü aç" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="Manuel yedek tamamlanınca klasörü otomatik aç" FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
            </ScrollViewer>
            <Border Grid.Row="2" Background="{DynamicResource BgSecondary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
              <DockPanel Margin="24,0">
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveSettingsCommand}" Padding="28,10" Height="40">
                  <TextBlock Text="Kaydet" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                             Foreground="White"/>
                </Button>
              </DockPanel>
            </Border>
          </Grid>

        </Grid>
      </Grid>

      <!-- ══ İLERLEME BARI ════════════════════════════════════════════════ -->
      <Border Grid.Row="2" Background="{DynamicResource BgSecondary}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
        <Border.Visibility>
          <Binding Path="ShowProgressPanel" Converter="{StaticResource BoolToVis}"/>
        </Border.Visibility>
        <Grid Margin="16,10,16,12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <!-- Kategori + dosya + hız + kalan -->
          <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <TextBlock Text="{Binding FileCountText}" FontFamily="Consolas" FontSize="10"
                         Foreground="{DynamicResource AccentLight}" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding SpeedText}" FontFamily="Consolas" FontSize="10"
                         Foreground="{DynamicResource TextTertiary}" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="ETA: " FontSize="10" Foreground="{DynamicResource TextTertiary}"
                         FontFamily="Consolas" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding EtaText}" FontFamily="Consolas" FontSize="10"
                         Foreground="{DynamicResource AccentLight}" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock VerticalAlignment="Center" FontSize="12" FontFamily="Segoe UI">
              <Run Text="{Binding CurrentCategory, Mode=OneWay}"
                   Foreground="{DynamicResource Accent}" FontWeight="SemiBold"/>
              <Run Text=" — " Foreground="{DynamicResource TextTertiary}"/>
              <Run Text="{Binding CurrentFile, Mode=OneWay}"
                   Foreground="{DynamicResource TextSecondary}"/>
            </TextBlock>
          </DockPanel>
          <!-- Progress bar -->
          <ProgressBar Grid.Row="2" Style="{StaticResource ItchyProgressBar}"
                       Value="{Binding ProgressPercent}" Maximum="100"/>
          <!-- Yüzde + durum -->
          <DockPanel Grid.Row="3" Margin="0,5,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold">
                <TextBlock.Foreground>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00A050" Offset="0"/>
                    <GradientStop Color="#00FF80" Offset="1"/>
                  </LinearGradientBrush>
                </TextBlock.Foreground>
                <Run Text="{Binding ProgressPercent, StringFormat='{}{0:F0}', Mode=OneWay}"/>
                <Run Text="%"/>
              </TextBlock>
            </StackPanel>
            <TextBlock Text="{Binding ProgressText}" FontSize="10" FontFamily="Consolas"
                       Foreground="{DynamicResource TextTertiary}"/>
          </DockPanel>
        </Grid>
      </Border>

      <!-- ══ STATUS BAR ════════════════════════════════════════════════════ -->
      <Border Grid.Row="3" Background="{DynamicResource BgSecondary}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
        <DockPanel Margin="16,0">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="7" Height="7" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="{DynamicResource Accent}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                      <Setter Property="Fill" Value="{DynamicResource Warning}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
              <Ellipse.Effect>
                <DropShadowEffect Color="#6C5CE7" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
              </Ellipse.Effect>
            </Ellipse>
            <TextBlock FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text" Value="● Hazır"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                      <Setter Property="Text" Value="◉ Yedekleniyor..."/>
                      <Setter Property="Foreground" Value="{DynamicResource Warning}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>
          <TextBlock Text="- Created by M.Mert -                                                                                                                                    - Itchy -"
                     FontSize="11" FontFamily="Cascadia Code"
                     Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
        </DockPanel>
      </Border>
    </Grid>
  </Border>
</Window>
