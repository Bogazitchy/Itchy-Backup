                                        <Separator/>
                                        <DockPanel Margin="16,13">
                                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ItchyCheckBox}"
                                IsChecked="{Binding OpenFolderAfterBackup}" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="Yedek bitince klasörü aç" FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="Manuel yedek tamamlanınca klasörü otomatik aç" FontSize="11"
                                   Foreground="{StaticResource TextTertiary}" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
            </ScrollViewer>
            <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
              <DockPanel Margin="24,0">
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveSettingsCommand}" Padding="28,10" Height="40">
                  <TextBlock Text="Kaydet" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                             Foreground="White"/>
                </Button>
              </DockPanel>
            </Border>
          </Grid>

        </Grid>
      </Grid>

      <!-- ══ İLERLEME BARI ════════════════════════════════════════════════ -->
      <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
        <Border.Visibility>
          <Binding Path="ShowProgressPanel" Converter="{StaticResource BoolToVis}"/>
        </Border.Visibility>
        <Grid Margin="16,10,16,12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <!-- Kategori + dosya + hız + kalan -->
          <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <TextBlock Text="{Binding FileCountText}" FontFamily="Consolas" FontSize="10"
                         Foreground="{StaticResource AccentLight}" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding SpeedText}" FontFamily="Consolas" FontSize="10"
                         Foreground="{StaticResource TextTertiary}" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="ETA: " FontSize="10" Foreground="{StaticResource TextTertiary}"
                         FontFamily="Consolas" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding EtaText}" FontFamily="Consolas" FontSize="10"
                         Foreground="{StaticResource AccentLight}" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock VerticalAlignment="Center" FontSize="12" FontFamily="Segoe UI">
              <Run Text="{Binding CurrentCategory, Mode=OneWay}"
                   Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
              <Run Text=" — " Foreground="{StaticResource TextTertiary}"/>
              <Run Text="{Binding CurrentFile, Mode=OneWay}"
                   Foreground="{StaticResource TextSecondary}"/>
            </TextBlock>
          </DockPanel>
          <!-- Progress bar -->
          <ProgressBar Grid.Row="2" Style="{StaticResource ItchyProgressBar}"
                       Value="{Binding ProgressPercent}" Maximum="100"/>
          <!-- Yüzde + durum -->
          <DockPanel Grid.Row="3" Margin="0,5,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold">
                <TextBlock.Foreground>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00A050" Offset="0"/>
                    <GradientStop Color="#00FF80" Offset="1"/>
                  </LinearGradientBrush>
                </TextBlock.Foreground>
                <Run Text="{Binding ProgressPercent, StringFormat='{}{0:F0}', Mode=OneWay}"/>
                <Run Text="%"/>
              </TextBlock>
            </StackPanel>
            <TextBlock Text="{Binding ProgressText}" FontSize="10" FontFamily="Consolas"
                       Foreground="{StaticResource TextTertiary}"/>
          </DockPanel>
        </Grid>
      </Border>

      <!-- ══ STATUS BAR ════════════════════════════════════════════════════ -->
      <Border Grid.Row="3" Background="{StaticResource BgSecondary}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
        <DockPanel Margin="16,0">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="7" Height="7" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="{StaticResource Accent}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                      <Setter Property="Fill" Value="{StaticResource Warning}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
              <Ellipse.Effect>
                <DropShadowEffect Color="#6C5CE7" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
              </Ellipse.Effect>
            </Ellipse>
            <TextBlock FontSize="10" FontFamily="Consolas" Foreground="{StaticResource TextTertiary}">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text" Value="● Hazır"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                      <Setter Property="Text" Value="◉ Yedekleniyor..."/>
                      <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>
          <TextBlock Text="Created by M.Mert — Teknik Servis Yedekleme Aracı"
                     FontSize="10" FontFamily="Consolas"
                     Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center"/>
        </DockPanel>
      </Border>
    </Grid>
  </Border>
</Window>
