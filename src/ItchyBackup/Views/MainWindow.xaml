                        <Binding Path="IsBackingUp" Converter="{StaticResource BoolToVis}"/>
                      </Button.Visibility>
                      <TextBlock Text="✕  İptal Et" FontFamily="Segoe UI" FontSize="12"/>
                    </Button>
                  </StackPanel>
                </Border>
              </Grid>
            </Border>
          </Grid>

          <!-- ═══ GEÇMİŞ ════════════════════════════════════════════════ -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPanelHistory}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
              <RowDefinition Height="48"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{DynamicResource BgPrimary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
              <TextBlock Text="Yedekleme Geçmişi" FontSize="15" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                         Margin="16,0" FontFamily="Segoe UI"/>
            </Border>
            <ScrollViewer Grid.Row="1" Margin="16,12" VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <ItemsControl ItemsSource="{Binding BackupHistory}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:HistoryEntry}">
                      <Border Background="{DynamicResource BgCard}" CornerRadius="10"
                              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                              Margin="0,0,0,8">
                        <Grid>
                          <Border HorizontalAlignment="Left" Width="3" CornerRadius="10,0,0,10">
                            <Border.Style>
                              <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource Accent}"/>
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Danger}"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                          </Border>
                          <Grid Margin="16,12,14,12">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                              <TextBlock Text="{Binding FolderName}" FontSize="13" FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                              <TextBlock Text="{Binding Date}" FontSize="10" FontFamily="Consolas"
                                         Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                              <TextBlock Text="{Binding Summary}" FontSize="11"
                                         Foreground="{DynamicResource TextSecondary}"
                                         FontFamily="Segoe UI" Margin="0,3,0,0"/>
                              <TextBlock Text="{Binding DestinationRoot}" FontSize="10" FontFamily="Consolas"
                                         Foreground="{DynamicResource TextTertiary}" Margin="0,4,0,0"
                                         TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                              <Border VerticalAlignment="Top" CornerRadius="8" Padding="10,4"
                                      HorizontalAlignment="Right">
                                <Border.Style>
                                  <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                        <Setter Property="Background" Value="#1A0A0A"/>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </Border.Style>
                                <TextBlock FontSize="10" FontFamily="Consolas" FontWeight="Medium">
                                  <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                      <Setter Property="Text" Value="✓ Başarılı"/>
                                      <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                      <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                          <Setter Property="Text" Value="✕ Hata var"/>
                                          <Setter Property="Foreground" Value="{DynamicResource Danger}"/>
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </TextBlock.Style>
                                </TextBlock>
                              </Border>
                              <Button Style="{StaticResource SecondaryButton}" Margin="0,6,0,0"
                                      Padding="8,5" HorizontalAlignment="Right"
                                      Command="{Binding DataContext.OpenHistoryFolderCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                      CommandParameter="{Binding DestinationPath}"
                                      ToolTip="{Binding DestinationPath}">
                                <StackPanel Orientation="Horizontal">
                                  <TextBlock Text="📁" FontFamily="Segoe UI Emoji" FontSize="11"
                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                  <TextBlock Text="Konuma Git" FontFamily="Segoe UI" FontSize="10"
                                             VerticalAlignment="Center"/>
                                </StackPanel>
                              </Button>
                            </StackPanel>
                          </Grid>
                          <!-- Glass top highlight strip -->
                          <Border Height="1" VerticalAlignment="Top" IsHitTestVisible="False">
                            <Border.Background>
                              <LinearGradientBrush StartPoint="0,0" EndPoint="0,0">
                                <GradientStop Color="#2EFFFFFF" Offset="0"/>
                                <GradientStop Color="#06FFFFFF" Offset="1"/>
                              </LinearGradientBrush>
                            </Border.Background>
                          </Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Boş state -->
                <StackPanel HorizontalAlignment="Center" Margin="0,80,0,0">
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Collapsed"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding BackupHistory.Count}" Value="0">
                          <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <Border Width="64" Height="64" CornerRadius="32"
                          Background="{DynamicResource AccentSubtle}"
                          HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Viewbox Width="32" Height="32">
                      <Canvas Width="24" Height="24">
                        <Path Data="M13,2.03V2.05L13,4.05C17.39,4.59 20.5,8.58 19.96,12.97C19.5,16.61 16.64,19.5 13,19.93V21.93C18.5,21.38 22.5,16.5 21.95,11C21.5,6.25 17.73,2.5 13,2.03M11,2.06C9.05,2.25 7.19,3 5.67,4.26L7.1,5.74C8.22,4.84 9.57,4.26 11,4.06V2.06M4.26,5.67C3,7.19 2.25,9.04 2.05,11H4.05C4.24,9.58 4.8,8.23 5.69,7.1L4.26,5.67M15,11H11V17L16,12L15,11M4.06,13C4.26,14.43 4.83,15.78 5.72,16.9L7.15,15.47C6.25,14.35 5.69,13 5.47,13H4.06M7.1,18.37L5.67,19.74C7.18,21 9.04,21.79 11,22V20C9.58,19.8 8.22,19.24 7.1,18.37Z"
                              Fill="{DynamicResource Accent}"/>
