                    <Button Style="{StaticResource NeonPrimaryButton}" Command="{Binding StartBackupCommand}"
                            HorizontalAlignment="Stretch" Height="48">
                      <Button.IsEnabled>
                        <Binding Path="IsBackingUp" Converter="{StaticResource InverseBool}"/>
                      </Button.IsEnabled>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶  " FontSize="16" VerticalAlignment="Center"
                                   Foreground="White"/>
                        <TextBlock Text="Yedeği Başlat" FontSize="15" FontWeight="Bold"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"
                                   Foreground="White"/>
                      </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DangerButton}" Command="{Binding CancelBackupCommand}"
                            HorizontalAlignment="Stretch" Margin="0,8,0,0" Height="36">
