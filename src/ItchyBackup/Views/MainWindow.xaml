<Window x:Class="ItchyBackup.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ItchyBackup.ViewModels"
        xmlns:models="clr-namespace:ItchyBackup.Models"
        Title="Itchy Backup" Width="1100" Height="720" MinWidth="960" MinHeight="620"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen">
  <Window.DataContext>
    <vm:MainViewModel/>
  </Window.DataContext>

  <Border CornerRadius="12" Background="{StaticResource BgPrimary}"
          BorderBrush="{StaticResource BorderHoverBrush}" BorderThickness="1" ClipToBounds="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="48"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="28"/>
      </Grid.RowDefinitions>

      <!-- ══ TITLEBAR ══════════════════════════════════════════════════════ -->
      <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
              MouseLeftButtonDown="TitleBar_MouseDown">
        <Grid Margin="14,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="30" Height="30" CornerRadius="8" Background="{StaticResource Accent}" Margin="0,0,10,0">
              <Viewbox Width="16" Height="16">
                <Canvas Width="24" Height="24">
                  <Rectangle Canvas.Left="1" Canvas.Top="4" Width="22" Height="16" RadiusX="2" RadiusY="2"
                             Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                  <Ellipse Canvas.Left="4" Canvas.Top="8" Width="5" Height="5" Stroke="White" StrokeThickness="1.2" Fill="Transparent"/>
                  <Ellipse Canvas.Left="15" Canvas.Top="8" Width="5" Height="5" Stroke="White" StrokeThickness="1.2" Fill="Transparent"/>
                  <Path Data="M7,14 Q12,12 17,14" Stroke="White" StrokeThickness="1.2" Fill="Transparent"/>
                  <Rectangle Canvas.Left="10" Canvas.Top="17" Width="4" Height="2" RadiusX="1" RadiusY="1" Fill="White" Opacity="0.8"/>
                </Canvas>
              </Viewbox>
            </Border>
            <TextBlock Text="Itchy Backup" FontSize="14" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" FontFamily="Segoe UI"/>
            <Border Background="{StaticResource BgQuaternary}" CornerRadius="10"
                    Width="48" Height="20" Margin="10,0,0,0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
              <TextBlock Text="v0.5" FontSize="10" FontFamily="Consolas"
                         Foreground="{StaticResource TextTertiary}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Click="MinimizeBtn_Click" Width="38" Height="28" Background="Transparent" BorderThickness="0" Cursor="Hand">
              <TextBlock Text="─" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
            </Button>
            <Button Click="MaximizeBtn_Click" Width="38" Height="28" Background="Transparent" BorderThickness="0" Cursor="Hand">
              <TextBlock Text="□" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
            </Button>
            <Button Click="CloseBtn_Click" Width="38" Height="28" Background="Transparent" BorderThickness="0" Cursor="Hand">
              <TextBlock Text="✕" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ══ ANA İÇERİK ════════════════════════════════════════════════════ -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="200"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── SOL SIDEBAR ─────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="10,14,10,0">
              <TextBlock Text="MENÜ" FontSize="9" FontFamily="Consolas"
                         Foreground="{StaticResource TextTertiary}" Margin="8,0,0,8"/>

              <!-- Yedek Seç -->
              <Border CornerRadius="8" Margin="0,1" Cursor="Hand">
                <Border.InputBindings>
                  <MouseBinding MouseAction="LeftClick" Command="{Binding OpenBackupCommand}"/>
                </Border.InputBindings>
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                        <Setter Property="Background" Value="#1A1440"/>
                      </DataTrigger>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgQuaternary}"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <DockPanel Margin="10,9">
                  <Border DockPanel.Dock="Right" CornerRadius="10" Padding="5,1" VerticalAlignment="Center">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                            <Setter Property="Background" Value="{StaticResource Accent}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding SelectedSummary}" FontSize="9" FontFamily="Consolas">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                              <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Border>
                  <TextBlock VerticalAlignment="Center" FontSize="13" FontFamily="Segoe UI">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="Yedek Seç"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </DockPanel>
              </Border>

              <!-- Geçmiş -->
              <Border CornerRadius="8" Margin="0,1" Cursor="Hand">
                <Border.InputBindings>
                  <MouseBinding MouseAction="LeftClick" Command="{Binding OpenHistoryCommand}"/>
                </Border.InputBindings>
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsPanelHistory}" Value="True">
                        <Setter Property="Background" Value="#1A1440"/>
                      </DataTrigger>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgQuaternary}"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock Margin="10,9" FontSize="13" FontFamily="Segoe UI" Text="Geçmiş">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPanelHistory}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                          <Setter Property="FontWeight" Value="Medium"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </Border>

              <!-- Zamanlayıcı -->
              <Border CornerRadius="8" Margin="0,1" Cursor="Hand">
                <Border.InputBindings>
                  <MouseBinding MouseAction="LeftClick" Command="{Binding OpenSchedulerCommand}"/>
                </Border.InputBindings>
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsPanelScheduler}" Value="True">
                        <Setter Property="Background" Value="#1A1440"/>
                      </DataTrigger>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgQuaternary}"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock Margin="10,9" FontSize="13" FontFamily="Segoe UI" Text="Zamanlayıcı">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPanelScheduler}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                          <Setter Property="FontWeight" Value="Medium"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </Border>

              <!-- Ayarlar -->
              <Border CornerRadius="8" Margin="0,1" Cursor="Hand">
                <Border.InputBindings>
                  <MouseBinding MouseAction="LeftClick" Command="{Binding OpenSettingsCommand}"/>
                </Border.InputBindings>
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsPanelSettings}" Value="True">
                        <Setter Property="Background" Value="#1A1440"/>
                      </DataTrigger>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgQuaternary}"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock Margin="10,9" FontSize="13" FontFamily="Segoe UI" Text="Ayarlar">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPanelSettings}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                          <Setter Property="FontWeight" Value="Medium"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </Border>

              <TextBlock Text="PROFİLLER" FontSize="9" FontFamily="Consolas"
                         Foreground="{StaticResource TextTertiary}" Margin="8,14,0,8"/>

              <ItemsControl ItemsSource="{Binding SavedProfiles}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type models:BackupProfile}">
                    <Border CornerRadius="8" Margin="0,1" Cursor="Hand">
                      <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.LoadProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding}"/>
                      </Border.InputBindings>
                      <Border.Style>
                        <Style TargetType="Border">
                          <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter Property="Background" Value="{StaticResource BgQuaternary}"/>
                            </Trigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <StackPanel Margin="10,7">
                        <TextBlock Text="{Binding ProfileName}" FontSize="12"
                                   Foreground="{StaticResource TextPrimary}" FontWeight="Medium" FontFamily="Segoe UI"/>
                        <TextBlock Text="{Binding LastUsed}" FontSize="9"
                                   Foreground="{StaticResource TextTertiary}" FontFamily="Consolas"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
            <Button Grid.Row="1" Style="{StaticResource SecondaryButton}"
                    Command="{Binding OpenLogFolderCommand}"
                    Margin="10,8" Content="Log Klasörü" FontFamily="Segoe UI"/>
          </Grid>
        </Border>

        <!-- ── PANEL ALANI ───────────────────────────────────────────────── -->
        <Grid Grid.Column="1">

          <!-- ═══ YEDEK SEÇ PANELİ ═══════════════════════════════════════ -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="265"/>
            </Grid.ColumnDefinitions>

            <!-- Kategori listesi -->
            <Grid Grid.Column="0">
              <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Border Grid.Row="0" Background="{StaticResource BgPrimary}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0">
                  <TextBlock Text="Yedek Kategorileri" FontSize="14" FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"
                             DockPanel.Dock="Left" FontFamily="Segoe UI"/>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding SelectAllCommand}"
                            Content="Tümünü Seç" Margin="0,0,6,0" FontSize="11" FontFamily="Segoe UI"/>
                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding ClearAllCommand}"
                            Content="Temizle" FontSize="11" FontFamily="Segoe UI"/>
                  </StackPanel>
                </DockPanel>
              </Border>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Categories}" Margin="12,10,8,10">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:BackupCategory}">
                      <Border Margin="0,0,0,8" CornerRadius="10"
                              Background="{StaticResource BgSecondary}"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                          <!-- Kategori başlığı -->
                          <Grid Margin="12,10" Cursor="Hand">
                            <Grid.InputBindings>
                              <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleExpandCommand}"/>
                            </Grid.InputBindings>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="26"/>
                              <ColumnDefinition Width="42"/>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="48"/>
                              <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" Style="{StaticResource ItchyCheckBox}"
                                      IsChecked="{Binding MasterChecked}" VerticalAlignment="Center"
                                      PreviewMouseLeftButtonDown="CategoryCheckBox_MouseDown" Tag="{Binding}"/>
                            <!-- Kategori ikon: tam oturan border -->
                            <Border Grid.Column="1" Width="34" Height="34" CornerRadius="8"
                                    VerticalAlignment="Center" Margin="0,0,8,0" ClipToBounds="True">
                              <Border.Background>
                                <Binding Path="AccentColor" Converter="{StaticResource StringToBrush}" ConverterParameter="25"/>
                              </Border.Background>
                              <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                  <Path Data="{Binding CategoryIconPath}" Fill="{Binding AccentColor, Converter={StaticResource StringToBrush}}"/>
                                </Canvas>
                              </Viewbox>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                         FontSize="13" Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                              <TextBlock Text="{Binding Description}" FontSize="10"
                                         Foreground="{StaticResource TextTertiary}" FontFamily="Consolas"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" FontSize="10" FontFamily="Consolas"
                                       Foreground="{StaticResource TextTertiary}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,6,0">
                              <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                              <Run Text=" / "/>
                              <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Grid.Column="4" Text="▾" FontSize="10"
                                       Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                      <Setter Property="RenderTransform">
                                        <Setter.Value><RotateTransform Angle="180" CenterX="5" CenterY="6"/></Setter.Value>
                                      </Setter>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </Grid>
                          <!-- Özel klasör ekle butonu (sadece CustomFolders kategorisi) -->
                          <Border>
                            <Border.Style>
                              <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                  <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                      <Condition Binding="{Binding IsExpanded}" Value="True"/>
                                      <Condition Binding="{Binding Type}" Value="CustomFolders"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                  </MultiDataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                                    Padding="14,10">
                              <Grid>
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="*"/>
                                  <ColumnDefinition Width="Auto"/>
                                  <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource ItchyTextBox}"
                                         Text="{Binding DataContext.NewCustomPath, UpdateSourceTrigger=PropertyChanged,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                         FontFamily="Consolas" FontSize="11"
                                         VerticalContentAlignment="Center"
                                         x:Name="CustomPathBox"/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding DataContext.BrowseCustomFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Margin="6,0,4,0" Padding="8,6" ToolTip="Klasör seç">
                                  <TextBlock Text="📁" FontFamily="Segoe UI Emoji" FontSize="13"/>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding DataContext.AddCustomFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Padding="12,6">
                                  <TextBlock Text="+ Ekle" FontFamily="Segoe UI" FontSize="11"/>
                                </Button>
                              </Grid>
                            </Border>
                          </Border>

                          <!-- Öğe listesi -->
                          <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.Style>
                              <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="{x:Type models:BackupItem}">
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Cursor="Hand">
                                  <Border.Style>
                                    <Style TargetType="Border">
                                      <Setter Property="Background" Value="Transparent"/>
                                      <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                          <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
                                        </Trigger>
                                      </Style.Triggers>
                                    </Style>
                                  </Border.Style>
                                  <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleSelectCommand}"/>
                                  </Border.InputBindings>
                                  <Grid Margin="18,7,12,7">
                                    <Grid.ColumnDefinitions>
                                      <ColumnDefinition Width="26"/>
                                      <ColumnDefinition Width="28"/>
                                      <ColumnDefinition Width="*"/>
                                      <ColumnDefinition Width="Auto"/>
                                      <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Style="{StaticResource ItchyCheckBox}"
                                              IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Width="24" Height="24" CornerRadius="6"
                                            VerticalAlignment="Center" Margin="0,0,8,0" ClipToBounds="True"
                                            Opacity="0.8">
                                      <Border.Background>
                                        <Binding Path="Parent.AccentColor" Converter="{StaticResource StringToBrush}" ConverterParameter="22"/>
                                      </Border.Background>
                                      <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                          <Path Data="{Binding Parent.CategoryIconPath}"
                                                Fill="{Binding Parent.AccentColor, Converter={StaticResource StringToBrush}}"/>
                                        </Canvas>
                                      </Viewbox>
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                      <TextBlock Text="{Binding Label}" FontSize="12"
                                                 Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                                      <TextBlock Text="{Binding Path}" FontSize="10" FontFamily="Consolas"
                                                 Foreground="{StaticResource TextTertiary}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="3" Margin="4,0" VerticalAlignment="Center">
                                      <Border.Style>
                                        <Style TargetType="Border">
                                          <Setter Property="Visibility" Value="Collapsed"/>
                                          <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDetected}" Value="False">
                                              <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </Border.Style>
                                      <Border Background="#1A1A22" CornerRadius="8" Padding="5,2"
                                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <TextBlock Text="kurulu değil" FontSize="9"
                                                   Foreground="{StaticResource TextTertiary}" FontFamily="Consolas"/>
                                      </Border>
                                    </Border>
                                    <Border Grid.Column="4" Margin="3,0" VerticalAlignment="Center">
                                      <Border.Style>
                                        <Style TargetType="Border">
                                          <Setter Property="Visibility" Value="Collapsed"/>
                                          <Style.Triggers>
                                            <DataTrigger Binding="{Binding RequiresVss}" Value="True">
                                              <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </Border.Style>
                                      <Border Background="#0A2A20" CornerRadius="8" Padding="5,2"
                                              BorderBrush="#1A4A38" BorderThickness="1">
                                        <TextBlock Text="VSS" FontSize="9"
                                                   Foreground="{StaticResource Success}" FontFamily="Consolas"/>
                                      </Border>
                                    </Border>
                                    <!-- Custom klasör sil butonu -->
                                    <Border Grid.Column="4" Margin="3,0" VerticalAlignment="Center">
                                      <Border.Style>
                                        <Style TargetType="Border">
                                          <Setter Property="Visibility" Value="Collapsed"/>
                                          <Style.Triggers>
                                            <DataTrigger Binding="{Binding Parent.Type}" Value="CustomFolders">
                                              <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </Border.Style>
                                      <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                              Command="{Binding DataContext.RemoveCustomFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                              CommandParameter="{Binding}"
                                              ToolTip="Kaldır" Padding="4,2">
                                        <TextBlock Text="✕" FontSize="10" Foreground="{StaticResource Danger}"/>
                                      </Button>
                                    </Border>
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>

            <!-- Sağ seçenek paneli -->
            <Border Grid.Column="1" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,14,16,16">
                  <TextBlock Text="YEDEK SEÇENEKLERİ" FontSize="9" FontFamily="Consolas"
                             Foreground="{StaticResource TextTertiary}" Margin="0,0,0,12"/>
                  <TextBlock Text="Hedef Klasör" FontSize="11" FontWeight="Medium"
                             Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6" FontFamily="Segoe UI"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ItchyTextBox}"
                             Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="11"/>
                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseDestinationCommand}"
                            Margin="6,0,0,0" Padding="10,8">
                      <TextBlock Text="📁" FontFamily="Segoe UI Emoji" FontSize="13"/>
                    </Button>
                  </Grid>
                  <Separator Margin="0,12,0,12"/>
                  <CheckBox Style="{StaticResource ItchyCheckBox}" IsChecked="{Binding UseZip}" Margin="0,0,0,8">
                    <TextBlock Text="ZIP olarak sıkıştır" FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource TextPrimary}"/>
                  </CheckBox>
                  <StackPanel>
                    <StackPanel.Style>
                      <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding UseZip}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
