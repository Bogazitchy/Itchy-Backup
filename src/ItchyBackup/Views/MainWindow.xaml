                                 Foreground="{StaticResource Danger}" FontFamily="Consolas" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                  <Border Background="{StaticResource BgCard}" CornerRadius="10" Margin="8,0,0,0"
                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                      <TextBlock Text="SÜRE" FontSize="9" FontFamily="Consolas"
                                 Foreground="{StaticResource TextTertiary}"/>
                      <TextBlock Text="{Binding LastBackupResult.Elapsed, StringFormat=mm\:ss}" FontSize="22" FontWeight="Bold"
                                 Foreground="{StaticResource Info}" FontFamily="Consolas" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                </UniformGrid>

                <!-- Doğrulama Raporu -->
                <Border Background="{StaticResource BgCard}" CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16" Padding="16,12"
                        Visibility="{Binding LastBackupResult.VerificationReport, Converter={StaticResource NotNullToVis}}">
                  <StackPanel>
                    <TextBlock Text="DOĞRULAMA" FontSize="9" FontFamily="Consolas"
                               Foreground="{StaticResource TextTertiary}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding LastBackupResult.VerificationReport.Summary}" FontSize="13"
                               Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="Geçerli" FontSize="10" Foreground="{StaticResource TextTertiary}"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="{Binding LastBackupResult.VerificationReport.Valid}"
                                   FontSize="16" FontWeight="Bold" Foreground="{StaticResource Success}"
                                   FontFamily="Consolas"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="Eksik" FontSize="10" Foreground="{StaticResource TextTertiary}"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="{Binding LastBackupResult.VerificationReport.Missing}"
                                   FontSize="16" FontWeight="Bold" Foreground="{StaticResource Danger}"
                                   FontFamily="Consolas"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Text="Bozuk" FontSize="10" Foreground="{StaticResource TextTertiary}"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="{Binding LastBackupResult.VerificationReport.Modified}"
                                   FontSize="16" FontWeight="Bold" Foreground="{StaticResource Warning}"
                                   FontFamily="Consolas"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- Hata listesi -->
                <Border Background="{StaticResource BgCard}" CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,16" Padding="0">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding LastBackupResult.Errors.Count, Converter={StaticResource HasItemsConverter}}" Value="True">
                          <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <StackPanel>
                    <TextBlock Text="HATALAR" FontSize="9" FontFamily="Consolas"
                               Foreground="{StaticResource Danger}" Margin="16,12,16,8"/>
                    <ItemsControl ItemsSource="{Binding LastBackupResult.Errors}" MaxHeight="160">
                      <ItemsControl.Template>
                        <ControlTemplate>
                          <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter/>
                          </ScrollViewer>
                        </ControlTemplate>
                      </ItemsControl.Template>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Padding="16,4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding}" FontSize="10" FontFamily="Consolas"
                                       Foreground="{StaticResource Danger}" TextWrapping="Wrap"/>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

              </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="20,12">
