<Window x:Class="ItchyBackup.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ItchyBackup.ViewModels"
        xmlns:models="clr-namespace:ItchyBackup.Models"
        Title="Itchy Backup" Width="1140" Height="740"
        MinWidth="980" MinHeight="640"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
  <Window.DataContext>
    <vm:MainViewModel/>
  </Window.DataContext>

  <Border CornerRadius="12" BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="1"
          Background="{DynamicResource WindowBgBrush}"
          ClipToBounds="True">
    <Border.Effect>
      <DropShadowEffect Color="#6C5CE7" BlurRadius="42" ShadowDepth="0" Opacity="0.32"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="52"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="30"/>
      </Grid.RowDefinitions>

      <!-- ══ TITLEBAR ═════════════════════════════════════════════════════ -->
      <Border Grid.Row="0" Background="{DynamicResource TitleBarBrush}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
              MouseLeftButtonDown="TitleBar_MouseDown">
        <Grid>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
            <!-- Logo -->
            <Border Width="32" Height="32" CornerRadius="9"
                    Margin="0,0,12,0">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#4A3CB5" Offset="0"/>
                  <GradientStop Color="#6C5CE7" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <Border.Effect>
                <DropShadowEffect Color="#6C5CE7" BlurRadius="10" ShadowDepth="0" Opacity="2"/>
              </Border.Effect>
              <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                  <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                      <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                       From="8" To="26" Duration="0:0:2.0">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                      <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                       From="0.35" To="0.88" Duration="0:0:2.0">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </Border.Triggers>
              <Viewbox Width="18" Height="18">
                <Canvas Width="24" Height="24">
                  <Rectangle Canvas.Left="1" Canvas.Top="4" Width="22" Height="16"
                             RadiusX="2" RadiusY="2"
                             Stroke="#080C0A" StrokeThickness="1.5" Fill="Transparent"/>
                  <Ellipse Canvas.Left="4" Canvas.Top="8" Width="5" Height="5"
                           Stroke="#080C0A" StrokeThickness="1.2" Fill="Transparent"/>
                  <Ellipse Canvas.Left="15" Canvas.Top="8" Width="5" Height="5"
                           Stroke="#080C0A" StrokeThickness="1.2" Fill="Transparent"/>
                  <Path Data="M7,14 Q12,12 17,14" Stroke="#080C0A" StrokeThickness="1.2" Fill="Transparent"/>
                  <Rectangle Canvas.Left="10" Canvas.Top="17" Width="4" Height="2"
                             RadiusX="1" RadiusY="1" Fill="#080C0A" Opacity="0.8"/>
                </Canvas>
              </Viewbox>
            </Border>
            <StackPanel>
              <TextBlock Text="Itchy Backup" FontSize="14" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
              <TextBlock Text="Teknik Servis Dosya Yedekleme Aracı" FontSize="9"
                         Foreground="{DynamicResource TextTertiary}" FontFamily="Consolas"/>
            </StackPanel>
            <Border Background="{DynamicResource BgQuaternary}" CornerRadius="10"
                    Padding="8,3" Margin="14,0,0,0"
                    BorderBrush="{DynamicResource AccentDark}" BorderThickness="1">
              <Border.Effect>
                <DropShadowEffect Color="#6C5CE7" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
              </Border.Effect>
              <TextBlock Text="v0.7" FontSize="10" FontFamily="Consolas"
                         Foreground="{DynamicResource AccentLight}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </StackPanel>
          <!-- Pencere butonları -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">

            <!-- Küçült -->
            <Button Click="MinimizeBtn_Click" Width="48" Height="52"
                    BorderThickness="0" Cursor="Hand" ToolTip="Küçült">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                    <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Rectangle x:Name="Icon" Canvas.Left="3" Canvas.Top="11.5"
                                   Width="18" Height="1.5" RadiusX="0.75" RadiusY="0.75"
                                   Fill="{DynamicResource TextTertiary}"/>
                      </Canvas>
                    </Viewbox>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BgTertiary}"/>
                      <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource TextPrimary}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BgQuaternary}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>

            <!-- Büyüt / Geri al -->
            <Button Click="MaximizeBtn_Click" Width="48" Height="52"
                    BorderThickness="0" Cursor="Hand" ToolTip="Büyüt">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                    <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Rectangle x:Name="Icon" Canvas.Left="3.5" Canvas.Top="3.5"
                                   Width="17" Height="17" RadiusX="2.5" RadiusY="2.5"
                                   Stroke="{DynamicResource TextTertiary}" StrokeThickness="1.6" Fill="Transparent"/>
                      </Canvas>
                    </Viewbox>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BgTertiary}"/>
                      <Setter TargetName="Icon" Property="Stroke" Value="{DynamicResource TextPrimary}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BgQuaternary}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>

            <!-- Kapat -->
            <Button Click="CloseBtn_Click" Width="48" Height="52"
                    BorderThickness="0" Cursor="Hand" ToolTip="Kapat">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                    <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path x:Name="Icon"
                              Data="M4.5,4.5 L19.5,19.5 M19.5,4.5 L4.5,19.5"
                              Stroke="{DynamicResource TextTertiary}" StrokeThickness="1.7"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                      </Canvas>
                    </Viewbox>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Bg" Property="Background" Value="#C42B1C"/>
                      <Setter TargetName="Icon" Property="Stroke" Value="White"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="Bg" Property="Background" Value="#9B2318"/>
                      <Setter TargetName="Icon" Property="Stroke" Value="White"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>

          </StackPanel>
        </Grid>
      </Border>

      <!-- ══ ANA İÇERİK ════════════════════════════════════════════════════ -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── SOL SIDEBAR ───────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="12,16,12,0">

                <TextBlock Text="NAVİGASYON" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}"
                           Margin="10,0,0,10"/>

                <!-- Sidebar Nav Item Template -->
                <!-- Yedek Seç -->
                <Border CornerRadius="8" Margin="0,1" Cursor="Hand" Height="42">
                  <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenBackupCommand}"/>
                  </Border.InputBindings>
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="Transparent"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <Grid>
                    <!-- Aktif gösterge çizgisi -->
                    <Border HorizontalAlignment="Left" Width="3" CornerRadius="10,3,3,10">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="Transparent"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                              <Setter Property="Background" Value="{DynamicResource Accent}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <Border.Effect>
                        <DropShadowEffect Color="#6C5CE7" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                      </Border.Effect>
                      <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                          <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                               From="5" To="18" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                              </DoubleAnimation>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                               From="0.4" To="1.0" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                              </DoubleAnimation>
                            </Storyboard>
                          </BeginStoryboard>
                        </EventTrigger>
                      </Border.Triggers>
                    </Border>
                    <DockPanel Margin="14,0,10,0">
                      <Border DockPanel.Dock="Right" CornerRadius="10" Padding="7,2" VerticalAlignment="Center">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentDark}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SelectedSummary}" FontSize="9" FontFamily="Consolas">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                                  <Setter Property="Foreground" Value="{DynamicResource AccentLight}"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Border>
                      <TextBlock Text="Yedek Seç" VerticalAlignment="Center"
                                 FontSize="13" FontFamily="Segoe UI">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </DockPanel>
                  </Grid>
                </Border>

                <!-- Geçmiş -->
                <Border CornerRadius="8" Margin="0,1" Cursor="Hand" Height="42">
                  <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenHistoryCommand}"/>
                  </Border.InputBindings>
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="Transparent"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPanelHistory}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <Grid>
                    <Border HorizontalAlignment="Left" Width="3" CornerRadius="10,3,3,10">
                      <Border.Effect>
                        <DropShadowEffect Color="#6C5CE7" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                      </Border.Effect>
                      <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                          <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                               From="5" To="18" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                              </DoubleAnimation>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                               From="0.4" To="1.0" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                              </DoubleAnimation>
                            </Storyboard>
                          </BeginStoryboard>
                        </EventTrigger>
                      </Border.Triggers>
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="Transparent"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPanelHistory}" Value="True">
                              <Setter Property="Background" Value="{DynamicResource Accent}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                    </Border>
                    <TextBlock Margin="14,0" VerticalAlignment="Center"
                               FontSize="13" FontFamily="Segoe UI" Text="Geçmiş">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPanelHistory}" Value="True">
                              <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                              <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Grid>
                </Border>

                <!-- Zamanlayıcı -->
                <Border CornerRadius="8" Margin="0,1" Cursor="Hand" Height="42">
                  <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenSchedulerCommand}"/>
                  </Border.InputBindings>
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="Transparent"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPanelScheduler}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <Grid>
                    <Border HorizontalAlignment="Left" Width="3" CornerRadius="10,3,3,10">
                      <Border.Effect>
                        <DropShadowEffect Color="#6C5CE7" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                      </Border.Effect>
                      <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                          <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                               From="5" To="18" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                              </DoubleAnimation>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                               From="0.4" To="1.0" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                              </DoubleAnimation>
                            </Storyboard>
                          </BeginStoryboard>
                        </EventTrigger>
                      </Border.Triggers>
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="Transparent"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPanelScheduler}" Value="True">
                              <Setter Property="Background" Value="{DynamicResource Accent}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                    </Border>
                    <TextBlock Margin="14,0" VerticalAlignment="Center"
                               FontSize="13" FontFamily="Segoe UI" Text="Zamanlayıcı">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPanelScheduler}" Value="True">
                              <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                              <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Grid>
                </Border>

                <!-- Geri Yükle -->
                <Border CornerRadius="8" Margin="0,1" Cursor="Hand" Height="42">
                  <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenRestoreCommand}"/>
                  </Border.InputBindings>
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="Transparent"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPanelRestore}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <Grid>
                    <Border HorizontalAlignment="Left" Width="3" CornerRadius="10,3,3,10">
                      <Border.Effect>
                        <DropShadowEffect Color="#6C5CE7" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                      </Border.Effect>
                      <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                          <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                               From="5" To="18" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                              </DoubleAnimation>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                               From="0.4" To="1.0" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                              </DoubleAnimation>
                            </Storyboard>
                          </BeginStoryboard>
                        </EventTrigger>
                      </Border.Triggers>
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="Transparent"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPanelRestore}" Value="True">
                              <Setter Property="Background" Value="{DynamicResource Accent}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                    </Border>
                    <TextBlock Margin="14,0" VerticalAlignment="Center"
                               FontSize="13" FontFamily="Segoe UI" Text="Geri Yükle">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPanelRestore}" Value="True">
                              <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                              <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Grid>
                </Border>

                <!-- Ayarlar -->
                <Border CornerRadius="8" Margin="0,1" Cursor="Hand" Height="42">
                  <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenSettingsCommand}"/>
                  </Border.InputBindings>
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="Transparent"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPanelSettings}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <Grid>
                    <Border HorizontalAlignment="Left" Width="3" CornerRadius="10,3,3,10">
                      <Border.Effect>
                        <DropShadowEffect Color="#6C5CE7" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                      </Border.Effect>
                      <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                          <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                               From="5" To="18" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                              </DoubleAnimation>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                               From="0.4" To="1.0" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                              </DoubleAnimation>
                            </Storyboard>
                          </BeginStoryboard>
                        </EventTrigger>
                      </Border.Triggers>
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="Transparent"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPanelSettings}" Value="True">
                              <Setter Property="Background" Value="{DynamicResource Accent}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                    </Border>
                    <TextBlock Margin="14,0" VerticalAlignment="Center"
                               FontSize="13" FontFamily="Segoe UI" Text="Ayarlar">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPanelSettings}" Value="True">
                              <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                              <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Grid>
                </Border>

                <!-- Profiller -->
                <TextBlock Text="PROFİLLER" FontSize="9" FontFamily="Consolas"
                           Foreground="{DynamicResource TextTertiary}"
                           Margin="10,18,0,10"/>

                <ItemsControl ItemsSource="{Binding SavedProfiles}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:BackupProfile}">
                      <Border CornerRadius="8" Margin="0,1" Cursor="Hand" Padding="12,8">
                        <Border.InputBindings>
                          <MouseBinding MouseAction="LeftClick"
                                        Command="{Binding DataContext.LoadProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                              </Trigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <DockPanel>
                          <!-- Profil ikon -->
                          <Border DockPanel.Dock="Left" Width="30" Height="30" CornerRadius="8"
                                  Background="{DynamicResource AccentSubtle}"
                                  BorderBrush="{DynamicResource Accent}" BorderThickness="1"
                                  Margin="0,0,10,0">
                            <Viewbox Width="16" Height="16"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                              <Canvas Width="024" Height="24">
                                <Path Data="{Binding IconPath}" Fill="{DynamicResource AccentLight}"/>
                              </Canvas>
                            </Viewbox>
                          </Border>
                          <!-- Sil butonu -->
                          <Button DockPanel.Dock="Right" VerticalAlignment="Center"
                                  Width="20" Height="20" Margin="6,0,0,0"
                                  Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"
                                  ToolTip="Profili Sil">
                            <Button.Style>
                              <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Opacity" Value="0.35"/>
                                <Setter Property="Template">
                                  <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                      <Border Background="{TemplateBinding Background}"
                                              CornerRadius="4"
                                              Width="20" Height="20">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                      </Border>
                                    </ControlTemplate>
                                  </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                  <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A0A0A"/>
                                    <Setter Property="Opacity" Value="1"/>
                                  </Trigger>
                                </Style.Triggers>
                              </Style>
                            </Button.Style>
                            <Viewbox Width="11" Height="11">
                              <Canvas Width="24" Height="24">
                                <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                      Fill="{DynamicResource Danger}"/>
                              </Canvas>
                            </Viewbox>
                          </Button>
                          <!-- Düzenle butonu -->
                          <Button DockPanel.Dock="Right" VerticalAlignment="Center"
                                  Width="20" Height="20" Margin="0,0,0,0"
                                  Command="{Binding DataContext.EditProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"
                                  ToolTip="Profili Düzenle">
                            <Button.Style>
                              <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Opacity" Value="0.35"/>
                                <Setter Property="Template">
                                  <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                      <Border Background="{TemplateBinding Background}"
                                              CornerRadius="4"
                                              Width="20" Height="20">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                      </Border>
                                    </ControlTemplate>
                                  </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                  <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A2A3A"/>
                                    <Setter Property="Opacity" Value="1"/>
                                  </Trigger>
                                </Style.Triggers>
                              </Style>
                            </Button.Style>
                            <Viewbox Width="11" Height="11">
                              <Canvas Width="24" Height="24">
                                <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                      Fill="{DynamicResource AccentLight}"/>
                              </Canvas>
                            </Viewbox>
                          </Button>
                          <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ProfileName}" FontSize="12"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontWeight="Medium" FontFamily="Segoe UI"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding LastUsed}" FontSize="9"
                                       Foreground="{DynamicResource TextTertiary}"
                                       FontFamily="Consolas" Margin="0,1,0,0"/>
                          </StackPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Profil yok -->
                <Border Padding="10,12" Margin="0,4">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding SavedProfiles.Count}" Value="0">
                          <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="─" FontSize="18" Foreground="{DynamicResource TextTertiary}"
                               HorizontalAlignment="Center" FontFamily="Consolas"/>
                    <TextBlock Text="Profil yok" FontSize="11"
                               Foreground="{DynamicResource TextTertiary}"
                               HorizontalAlignment="Center" FontFamily="Segoe UI"
                               FontStyle="Italic" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>

              </StackPanel>
            </ScrollViewer>

            <!-- Log butonu -->
            <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="12,10">
              <Button Style="{StaticResource SecondaryButton}"
                      Command="{Binding OpenLogFolderCommand}"
                      HorizontalAlignment="Stretch">
                <TextBlock Text="Log Klasörü" FontFamily="Segoe UI" FontSize="11"/>
              </Button>
            </Border>
          </Grid>
        </Border>

        <!-- ── SAĞ PANEL ALANI ────────────────────────────────────────── -->
        <Grid Grid.Column="1">

          <!-- ═══ YEDEK SEÇ ════════════════════════════════════════════ -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPanelBackup}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Kategori Listesi -->
            <Grid Grid.Column="0">
              <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <!-- Başlık çubuğu -->
              <Border Grid.Row="0" Background="{DynamicResource BgPrimary}"
                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0">
                  <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Yedek Kategorileri" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding SelectAllCommand}"
                            Margin="0,0,6,0" FontSize="11" FontFamily="Segoe UI" Padding="12,6">
                      <TextBlock Text="Tümünü Seç"/>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding ClearAllCommand}"
                            FontSize="11" FontFamily="Segoe UI" Padding="12,6">
                      <TextBlock Text="Temizle"/>
                    </Button>
                  </StackPanel>
                </DockPanel>
              </Border>

              <!-- Kategori listesi -->
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Categories}" Margin="14,12,10,12">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:BackupCategory}">
                      <!-- Kategori kartı -->
                      <Border Margin="0,0,0,8" CornerRadius="10"
                              Background="{DynamicResource BgCard}"
                              BorderThickness="1,1,1,1">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding SelectedCount}" Value="0">
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <Grid>
                          <!-- Sol aksan çizgisi -->
                          <Border HorizontalAlignment="Left" Width="3" CornerRadius="10,0,0,10"
                                  Background="{Binding AccentColor, Converter={StaticResource StringToBrush}}">
                            <Border.Style>
                              <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0.3"/>
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                          </Border>

                          <StackPanel Margin="3,0,0,0">
                            <!-- Kategori başlığı -->
                            <Grid Margin="14,10,14,10" Cursor="Hand">
                              <Grid.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleExpandCommand}"/>
                              </Grid.InputBindings>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="18"/>
                              </Grid.ColumnDefinitions>

                              <CheckBox Grid.Column="0" Style="{StaticResource ItchyCheckBox}"
                                        IsChecked="{Binding MasterChecked}" VerticalAlignment="Center"
                                        PreviewMouseLeftButtonDown="CategoryCheckBox_MouseDown"
                                        Tag="{Binding}"/>

                              <!-- Kategori ikonu - tam oturan -->
                              <Border Grid.Column="1" Width="36" Height="36" CornerRadius="9"
                                      VerticalAlignment="Center" Margin="0,0,4,0"
                                      ClipToBounds="True" SnapsToDevicePixels="True">
                                <Border.Background>
                                  <Binding Path="AccentColor" Converter="{StaticResource StringToBrush}"
                                           ConverterParameter="18"/>
                                </Border.Background>
                                <Viewbox Stretch="Uniform" Margin="8"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                  <Canvas Width="22" Height="24">
                                    <Path Data="{Binding CategoryIconPath}"
                                          Fill="{Binding AccentColor, Converter={StaticResource StringToBrush}}"/>
                                  </Canvas>
                                </Viewbox>
                              </Border>

                              <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           FontSize="13" Foreground="{DynamicResource TextPrimary}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding Description}" FontSize="10"
                                           Foreground="{DynamicResource TextTertiary}"
                                           FontFamily="Consolas" Margin="0,1,0,0"/>
                              </StackPanel>

                              <!-- Seçim sayacı -->
                              <Border Grid.Column="3" CornerRadius="8" Padding="6"
                                      VerticalAlignment="Center" HorizontalAlignment="Right"
                                      Margin="0,0,0,0">
                                <Border.Style>
                                  <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource BgQuaternary}"/>
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding SelectedCount}" Value="0">
                                        <Setter Property="Background" Value="Transparent"/>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </Border.Style>
                                <TextBlock FontSize="9" FontFamily="Consolas"
                                           VerticalAlignment="Center">
                                  <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                      <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                      <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCount}" Value="0">
                                          <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </TextBlock.Style>
                                  <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                                  <Run Text=" / "/>
                                  <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                                </TextBlock>
                              </Border>

                              <TextBlock Grid.Column="4" Text="▾" FontSize="10"
                                         Foreground="{DynamicResource TextTertiary}"
                                         VerticalAlignment="Center">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="RenderTransform">
                                          <Setter.Value>
                                            <RotateTransform Angle="180" CenterX="5" CenterY="6"/>
                                          </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>
                            </Grid>

                            <!-- Özel klasör ekle butonu -->
                            <Border>
                              <Border.Style>
                                <Style TargetType="Border">
                                  <Setter Property="Visibility" Value="Collapsed"/>
                                  <Style.Triggers>
                                    <MultiDataTrigger>
                                      <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsExpanded}" Value="True"/>
                                        <Condition Binding="{Binding Type}" Value="CustomFolders"/>
                                      </MultiDataTrigger.Conditions>
                                      <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </Border.Style>
                              <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                                      Padding="14,10">
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                  </Grid.ColumnDefinitions>
                                  <TextBox Grid.Column="0" Style="{StaticResource ItchyTextBox}"
                                           Text="{Binding DataContext.NewCustomPath, UpdateSourceTrigger=PropertyChanged,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontFamily="Consolas" FontSize="11"
                                           VerticalContentAlignment="Center"
                                           Height="34"/>
                                  <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                          Command="{Binding DataContext.BrowseCustomFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Margin="6,0,4,0" Padding="8,6" ToolTip="Klasör seç">
                                    <TextBlock Text="📁" FontFamily="Segoe UI Emoji" FontSize="13"/>
                                  </Button>
                                  <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                                          Command="{Binding DataContext.AddCustomFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Padding="12,6">
                                    <TextBlock Text="+ Ekle" FontFamily="Segoe UI" FontSize="11"
                                               FontWeight="Bold" Foreground="{DynamicResource BgPrimary}"/>
                                  </Button>
                                </Grid>
                              </Border>
                            </Border>

                            <!-- Öğe listesi -->
                            <ItemsControl ItemsSource="{Binding Items}">
                              <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                  <Setter Property="Visibility" Value="Collapsed"/>
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                      <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </ItemsControl.Style>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:BackupItem}">
                                  <Border BorderBrush="{DynamicResource BorderBrush}"
                                          BorderThickness="0,1,0,0" Cursor="Hand">
                                    <Border.Style>
                                      <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                          <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                                          </Trigger>
                                          <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                      <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleSelectCommand}"/>
                                    </Border.InputBindings>
                                    <Grid Margin="20,7,14,7">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                      </Grid.ColumnDefinitions>
                                      <CheckBox Grid.Column="0" Style="{StaticResource ItchyCheckBox}"
                                                IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                      <!-- Öğe mini ikonu - brand logo varsa onu, yoksa kategori ikonu -->
                                      <Border Grid.Column="1" Width="24" Height="24" CornerRadius="6"
                                              VerticalAlignment="Center" Margin="0,0,4,0"
                                              ClipToBounds="True" SnapsToDevicePixels="True">
                                        <Border.Background>
                                          <Binding Path="Parent.AccentColor" Converter="{StaticResource StringToBrush}"
                                                   ConverterParameter="18"/>
                                        </Border.Background>
                                        <Viewbox Stretch="Uniform" Margin="5"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                                          <Canvas Width="24" Height="24">
                                            <!-- Brand logo varsa onu göster -->
                                            <Path Visibility="{Binding HasBrandLogo, Converter={StaticResource BoolToVis}}"
                                                  Data="{Binding BrandLogoPath}"
                                                  Fill="{Binding Parent.AccentColor, Converter={StaticResource StringToBrush}}"/>
                                            <!-- Yoksa kategori ikonunu göster -->
                                            <Path Data="{Binding Parent.CategoryIconPath}"
                                                  Fill="{Binding Parent.AccentColor, Converter={StaticResource StringToBrush}}">
                                              <Path.Style>
                                                <Style TargetType="Path">
                                                  <Setter Property="Visibility" Value="Visible"/>
                                                  <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasBrandLogo}" Value="True">
                                                      <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                  </Style.Triggers>
                                                </Style>
                                              </Path.Style>
                                            </Path>
                                          </Canvas>
                                        </Viewbox>
                                      </Border>
                                      <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}" FontSize="12"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock Text="{Binding Path}" FontSize="10"
                                                   FontFamily="Consolas"
                                                   Foreground="{DynamicResource TextTertiary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                      </StackPanel>
                                      <!-- Kurulu değil -->
                                      <Border Grid.Column="3" Margin="4,0" VerticalAlignment="Center">
                                        <Border.Style>
                                          <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                              <DataTrigger Binding="{Binding IsDetected}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                              </DataTrigger>
                                            </Style.Triggers>
                                          </Style>
                                        </Border.Style>
                                        <Border Background="{DynamicResource BgQuaternary}" CornerRadius="8"
                                                Padding="6,2" BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1">
                                          <TextBlock Text="kurulu değil" FontSize="9"
                                                     Foreground="{DynamicResource TextTertiary}"
                                                     FontFamily="Consolas"/>
                                        </Border>
                                      </Border>
                                      <!-- VSS -->
                                      <Border Grid.Column="4" Margin="3,0" VerticalAlignment="Center">
                                        <Border.Style>
                                          <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                              <DataTrigger Binding="{Binding RequiresVss}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                              </DataTrigger>
                                            </Style.Triggers>
                                          </Style>
                                        </Border.Style>
                                        <Border Background="{DynamicResource AccentSubtle}" CornerRadius="8"
                                                Padding="6,2" BorderBrush="{DynamicResource AccentDark}"
                                                BorderThickness="1">
                                          <TextBlock Text="VSS" FontSize="9"
                                                     Foreground="{DynamicResource Accent}"
                                                     FontFamily="Consolas"/>
                                        </Border>
                                      </Border>
                                      <!-- Custom sil butonu -->
                                      <Border Grid.Column="5" Margin="3,0" VerticalAlignment="Center">
                                        <Border.Style>
                                          <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                              <DataTrigger Binding="{Binding Parent.Type}" Value="CustomFolders">
                                                <Setter Property="Visibility" Value="Visible"/>
                                              </DataTrigger>
                                            </Style.Triggers>
                                          </Style>
                                        </Border.Style>
                                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.RemoveCustomFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" Padding="4,2">
                                          <TextBlock Text="✕" FontSize="10" Foreground="{DynamicResource Danger}"/>
                                        </Button>
                                      </Border>
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Özel klasör boş state -->
                            <Border>
                              <Border.Style>
                                <Style TargetType="Border">
                                  <Setter Property="Visibility" Value="Collapsed"/>
                                  <Style.Triggers>
                                    <MultiDataTrigger>
                                      <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsExpanded}" Value="True"/>
                                        <Condition Binding="{Binding Type}" Value="CustomFolders"/>
                                        <Condition Binding="{Binding Items.Count}" Value="0"/>
                                      </MultiDataTrigger.Conditions>
                                      <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </Border.Style>
                              <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                                      Padding="20,16">
                                <StackPanel HorizontalAlignment="Center">
                                  <TextBlock Text="Henüz özel klasör eklenmedi." FontSize="12"
                                             Foreground="{DynamicResource TextTertiary}"
                                             HorizontalAlignment="Center" FontFamily="Segoe UI"
                                             FontStyle="Italic"/>
                                  <TextBlock Text="Yukarıdan bir klasör yolu girin veya 📁 ile seçin."
                                             FontSize="10" Foreground="{DynamicResource TextTertiary}"
                                             HorizontalAlignment="Center" FontFamily="Segoe UI"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                              </Border>
                            </Border>
                          </StackPanel>
                          <!-- Glass top highlight strip -->
                          <Border Height="1" VerticalAlignment="Top" IsHitTestVisible="False">
                            <Border.Background>
                              <LinearGradientBrush StartPoint="0,0" EndPoint="0,0">
                                <GradientStop Color="#2EFFFFFF" Offset="0"/>
                                <GradientStop Color="#08FFFFFF" Offset="0.7"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                              </LinearGradientBrush>
                            </Border.Background>
                          </Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>

            <!-- Sağ Seçenek Paneli -->
            <Border Grid.Column="1" Background="{DynamicResource BgPrimary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                  <StackPanel Margin="16,16,16,8">

                    <!-- Hedef klasör grubu -->
                    <Border Background="{DynamicResource BgTertiary}" CornerRadius="10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Margin="0,0,0,12" Padding="14,12">
                      <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                          <TextBlock Text="HEDEF KLASÖR" FontSize="9" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextTertiary}"/>
                          <TextBlock Text="{Binding SelectedSizeText}" FontSize="9" FontFamily="Consolas"
                                     Foreground="{DynamicResource AccentLight}" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <TextBox Grid.Column="0" Style="{StaticResource ItchyTextBox}"
                                   Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                                   FontFamily="Consolas" FontSize="11" Height="34"
                                   VerticalContentAlignment="Center"/>
                          <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                  Command="{Binding BrowseDestinationCommand}"
                                  Margin="6,0,0,0" Padding="10,6" Height="34">
                            <TextBlock Text="📁" FontFamily="Segoe UI Emoji" FontSize="13"/>
                          </Button>
                        </Grid>
                        <TextBlock Text="UNC paylaşım: \\sunucu\paylasim" FontSize="9"
                                   FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                                   Margin="0,4,0,0"/>

                        <!-- Ek Hedefler -->
                        <Separator Margin="0,10,0,8" Background="{DynamicResource BorderBrush}"/>
                        <DockPanel Margin="0,0,0,6">
                          <TextBlock Text="EK HEDEFLER" FontSize="9" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                          <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                  Command="{Binding AddDestinationCommand}"
                                  Padding="8,3">
                            <TextBlock Text="+ Ekle" FontFamily="Segoe UI" FontSize="10"/>
                          </Button>
