                                  <TextBlock Text="{Binding Label}" FontFamily="Segoe UI" FontSize="12"/>
                                </DataTemplate>
                              </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="Lütfen bir yedek seçin"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="10,0,30,0"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{DynamicResource TextTertiary}">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Visibility" Value="Collapsed"/>
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedIncrementalBase}" Value="{x:Null}">
                                      <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </Grid>
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <!-- Düzenleme modu banner -->
                    <Border Margin="10,0,10,8" CornerRadius="7" Padding="10,7"
                            Background="{DynamicResource AccentSubtle}" BorderBrush="{DynamicResource Accent}" BorderThickness="1"
                            Visibility="{Binding IsEditingProfile, Converter={StaticResource BoolToVis}}">
                      <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Command="{Binding CancelEditProfileCommand}"
                                ToolTip="Düzenlemeyi İptal Et"
                                Margin="6,0,0,0" VerticalAlignment="Center">
                          <Button.Style>
                            <Style TargetType="Button">
                              <Setter Property="Background" Value="Transparent"/>
                              <Setter Property="BorderThickness" Value="0"/>
                              <Setter Property="Cursor" Value="Hand"/>
                              <Setter Property="Opacity" Value="0.6"/>
                              <Setter Property="Template">
                                <Setter.Value>
                                  <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="3">
                                      <ContentPresenter/>
                                    </Border>
                                  </ControlTemplate>
                                </Setter.Value>
                              </Setter>
                              <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                  <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <Viewbox Width="9" Height="9">
                            <Canvas Width="24" Height="24">
                              <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                    Fill="{DynamicResource TextSecondary}"/>
                            </Canvas>
                          </Viewbox>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                          <TextBlock FontSize="9" FontFamily="Consolas"
                                     Foreground="{DynamicResource AccentLight}" Text="DÜZENLE MODU"/>
                          <TextBlock FontSize="11" FontFamily="Segoe UI" Margin="0,2,0,0"
                                     Foreground="{DynamicResource TextSecondary}"
                                     Text="{Binding EditingProfile.ProfileName}"
                                     FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                      </DockPanel>
                    </Border>

                    <!-- Profil kaydet -->
                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding SaveProfileCommand}"
                            HorizontalAlignment="Stretch" Margin="0,0,0,0">
                      <TextBlock FontFamily="Segoe UI" FontSize="12">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="💾  Profil Kaydet"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditingProfile}" Value="True">
                                <Setter Property="Text" Value="💾  Profili Güncelle"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Button>

                  </StackPanel>
                </ScrollViewer>

                <!-- Alt: Yedekle butonu — büyük ve belirgin -->
                <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="16,14">
