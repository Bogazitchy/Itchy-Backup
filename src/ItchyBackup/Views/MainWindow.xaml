                    </Grid>
                  </StackPanel>
                </Border>

                <!-- İstatistikler -->
                <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">
                  <Border Background="{StaticResource BgCard}" CornerRadius="10" Margin="0,0,8,0"
                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                      <TextBlock Text="KATEGORİ" FontSize="9" FontFamily="Consolas"
                                 Foreground="{StaticResource TextTertiary}"/>
                      <TextBlock Text="{Binding LastBackupResult.TotalCategories}" FontSize="22" FontWeight="Bold"
                                 Foreground="{StaticResource AccentLight}" FontFamily="Consolas" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                  <Border Background="{StaticResource BgCard}" CornerRadius="10" Margin="4,0"
                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                      <TextBlock Text="DOSYA" FontSize="9" FontFamily="Consolas"
                                 Foreground="{StaticResource TextTertiary}"/>
                      <TextBlock Text="{Binding LastBackupResult.FilesCopied}" FontSize="22" FontWeight="Bold"
                                 Foreground="{StaticResource Success}" FontFamily="Consolas" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                  <Border Background="{StaticResource BgCard}" CornerRadius="10" Margin="4,0"
                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                      <TextBlock Text="HATA" FontSize="9" FontFamily="Consolas"
