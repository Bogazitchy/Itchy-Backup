                        <TextBox Grid.Column="0" Style="{StaticResource ItchyTextBox}"
                                 Text="{Binding DefaultDestination, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" FontSize="11"/>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseDefaultDestinationCommand}"
                                Margin="6,0,0,0" Padding="10,8">
                          <TextBlock Text="📁" FontFamily="Segoe UI Emoji" FontSize="13"/>
                        </Button>
                      </Grid>
                    </StackPanel>
                    <Separator/>
                    <DockPanel Margin="16,12">
                      <CheckBox DockPanel.Dock="Right" Style="{StaticResource ItchyCheckBox}"
                                IsChecked="{Binding AutoChecksum}" VerticalAlignment="Center"/>
                      <StackPanel>
                        <TextBlock Text="Otomatik checksum doğrulama" FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                        <TextBlock Text="Her yedek sonrası SHA-256 ile doğrula" FontSize="11"
                                   Foreground="{StaticResource TextTertiary}" FontFamily="Segoe UI"/>
                      </StackPanel>
                    </DockPanel>
                    <Separator/>
                    <DockPanel Margin="16,12">
                      <CheckBox DockPanel.Dock="Right" Style="{StaticResource ItchyCheckBox}"
                                IsChecked="{Binding SoundNotification}" VerticalAlignment="Center"/>
                      <StackPanel>
                        <TextBlock Text="Ses bildirimi" FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                        <TextBlock Text="Yedekleme tamamlanınca bildirim sesi çal" FontSize="11"
                                   Foreground="{StaticResource TextTertiary}" FontFamily="Segoe UI"/>
                      </StackPanel>
                    </DockPanel>
                    <Separator/>
                    <DockPanel Margin="16,12">
                      <CheckBox DockPanel.Dock="Right" Style="{StaticResource ItchyCheckBox}"
                                IsChecked="{Binding OpenFolderAfterBackup}" VerticalAlignment="Center"/>
                      <StackPanel>
                        <TextBlock Text="Yedek bitince klasörü aç" FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                        <TextBlock Text="Manuel yedekleme tamamlanınca yedek klasörünü aç" FontSize="11"
                                   Foreground="{StaticResource TextTertiary}" FontFamily="Segoe UI"/>
                      </StackPanel>
                    </DockPanel>
                  </StackPanel>
                </Border>

                <TextBlock Text="HAKKINDA" FontSize="9" FontFamily="Consolas"
                           Foreground="{StaticResource TextTertiary}" Margin="0,0,0,10"/>
                <Border Background="{StaticResource BgSecondary}" CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,12">
                  <StackPanel>
                    <TextBlock Text="Itchy Backup v0.5" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                    <TextBlock Text="Teknik Servis Yedekleme Aracı" FontSize="11"
                               Foreground="{StaticResource TextTertiary}" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                    <TextBlock Text="Created by M.Mert" FontSize="11"
                               Foreground="{StaticResource AccentLight}" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
            <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
              <DockPanel Margin="24,0">
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveSettingsCommand}" Padding="24,8">
                  <TextBlock Text="Kaydet" FontFamily="Segoe UI" FontSize="12"/>
                </Button>
              </DockPanel>
            </Border>
          </Grid>

        </Grid>
      </Grid>

      <!-- ══ İLERLEME BARI ═════════════════════════════════════════════════ -->
      <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
        <Border.Visibility>
          <Binding Path="ShowProgressPanel" Converter="{StaticResource BoolToVis}"/>
        </Border.Visibility>
        <Grid Margin="16,10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <!-- Üst satır: kategori + dosya + hız + kalan -->
          <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <TextBlock Text="{Binding SpeedText}" FontFamily="Consolas" FontSize="10"
                         Foreground="{StaticResource TextTertiary}" Margin="0,0,10,0" VerticalAlignment="Center"/>
              <TextBlock Text="Kalan: " FontSize="10" Foreground="{StaticResource TextTertiary}"
                         FontFamily="Segoe UI" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding EtaText}" FontFamily="Consolas" FontSize="10"
                         Foreground="{StaticResource AccentLight}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock VerticalAlignment="Center" FontSize="11" FontFamily="Segoe UI">
              <Run Text="{Binding CurrentCategory, Mode=OneWay}" Foreground="{StaticResource AccentLight}" FontWeight="Medium"/>
              <Run Text=" — " Foreground="{StaticResource TextTertiary}"/>
              <Run Text="{Binding CurrentFile, Mode=OneWay}" Foreground="{StaticResource TextSecondary}"/>
            </TextBlock>
          </DockPanel>
          <!-- Progress bar -->
          <ProgressBar Grid.Row="1" Style="{StaticResource ItchyProgressBar}"
                       Value="{Binding ProgressPercent}" Maximum="100"/>
          <!-- Alt satır: yüzde + durum -->
          <DockPanel Grid.Row="2" Margin="0,4,0,0">
            <TextBlock DockPanel.Dock="Right" FontFamily="Consolas" FontSize="10"
                       Foreground="{StaticResource AccentLight}">
              <Run Text="{Binding ProgressPercent, StringFormat='{}{0:F0}', Mode=OneWay}"/>
              <Run Text="%" Foreground="{StaticResource TextTertiary}"/>
            </TextBlock>
            <TextBlock Text="{Binding ProgressText}" FontSize="10" FontFamily="Consolas"
                       Foreground="{StaticResource TextTertiary}"/>
          </DockPanel>
        </Grid>
      </Border>

      <!-- ══ STATUS BAR ════════════════════════════════════════════════════ -->
      <Border Grid.Row="3" Background="{StaticResource BgSecondary}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
        <DockPanel Margin="16,0">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="6" Height="6" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="{StaticResource Success}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                      <Setter Property="Fill" Value="{StaticResource Warning}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock FontSize="10" FontFamily="Consolas" Foreground="{StaticResource TextTertiary}">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text" Value="Hazır"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                      <Setter Property="Text" Value="Yedekleniyor..."/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>
          <TextBlock Text="Created by M.Mert — Teknik Servis Yedekleme Aracı"
                     FontSize="10" FontFamily="Consolas"
                     Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center"/>
        </DockPanel>
      </Border>
    </Grid>
  </Border>
</Window>
