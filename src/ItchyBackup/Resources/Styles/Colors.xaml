<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ── Ana Renkler ─────────────────────────────────────────────────────── -->
  <Color x:Key="BgPrimaryColor">#0F0F11</Color>
  <Color x:Key="BgSecondaryColor">#16161A</Color>
  <Color x:Key="BgTertiaryColor">#1E1E24</Color>
  <Color x:Key="BgQuaternaryColor">#26262E</Color>

  <Color x:Key="AccentColor">#6C5CE7</Color>
  <Color x:Key="AccentLightColor">#A29BFE</Color>
  <Color x:Key="SuccessColor">#00CEC9</Color>
  <Color x:Key="WarningColor">#FDCB6E</Color>
  <Color x:Key="DangerColor">#FF7675</Color>

  <Color x:Key="TextPrimaryColor">#E8E8F0</Color>
  <Color x:Key="TextSecondaryColor">#9898B0</Color>
  <Color x:Key="TextTertiaryColor">#5A5A72</Color>

  <Color x:Key="BorderColor">#1F1F28</Color>
  <Color x:Key="BorderHoverColor">#2E2E3A</Color>

  <!-- ── SolidColorBrush'lar ─────────────────────────────────────────────── -->
  <SolidColorBrush x:Key="BgPrimary"   Color="{StaticResource BgPrimaryColor}"/>
  <SolidColorBrush x:Key="BgSecondary" Color="{StaticResource BgSecondaryColor}"/>
  <SolidColorBrush x:Key="BgTertiary"  Color="{StaticResource BgTertiaryColor}"/>
  <SolidColorBrush x:Key="BgQuaternary" Color="{StaticResource BgQuaternaryColor}"/>
  <SolidColorBrush x:Key="Accent"      Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="AccentLight" Color="{StaticResource AccentLightColor}"/>
  <SolidColorBrush x:Key="Success"     Color="{StaticResource SuccessColor}"/>
  <SolidColorBrush x:Key="Warning"     Color="{StaticResource WarningColor}"/>
  <SolidColorBrush x:Key="Danger"      Color="{StaticResource DangerColor}"/>
  <SolidColorBrush x:Key="TextPrimary"    Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondary"  Color="{StaticResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="TextTertiary"   Color="{StaticResource TextTertiaryColor}"/>
  <SolidColorBrush x:Key="BorderBrush"    Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}"/>

  <!-- Kategori Aksan Renkleri -->
  <SolidColorBrush x:Key="CatUserFolders" Color="#6C5CE7"/>
  <SolidColorBrush x:Key="CatBrowsers"    Color="#00CEC9"/>
  <SolidColorBrush x:Key="CatOutlook"     Color="#0078D4"/>
  <SolidColorBrush x:Key="CatDatabases"   Color="#FDCB6E"/>
  <SolidColorBrush x:Key="CatVMs"         Color="#FF7675"/>
  <SolidColorBrush x:Key="CatCloud"       Color="#55EFC4"/>

  <!-- Transparent (shorthand) -->
  <SolidColorBrush x:Key="Transparent" Color="Transparent"/>

</ResourceDictionary>
